generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(cuid())

  email String @unique

  name String?

  passwordHash String

  adminSessionToken     String?   @unique
  adminSessionStartedAt DateTime?

  isPremium                  Boolean   @default(false)
  premiumSince               DateTime?

  trialStartedAt             DateTime?
  trialEndsAt                DateTime?

  stripeCustomerId           String?   @unique
  stripeSubscriptionId       String?   @unique
  stripePriceId              String?
  subscriptionStatus         String?
  subscriptionCurrentPeriodEnd DateTime?

  role String @default("client")

  createdAt DateTime @default(now())

  leads     Lead[]
  invoices  Invoice[]
  pitchDecks PitchDeck[]
  ebooks    Ebook[]
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  phone     String?
  message   String
  status    String   @default("nuevo")
  source    String?
  tags      String?
  priority  String?
  aiSummary String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  notes LeadNote[]
}

model LeadNote {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Invoice {
  id          String   @id @default(cuid())
  clientName  String
  clientEmail String
  company     String?
  status      String   @default("borrador")
  dueDate     DateTime?
  subtotal    Float    @default(0)
  tax         Float    @default(0)
  total       Float    @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  InvoiceItem[]
}

model InvoiceItem {
  id          String @id @default(cuid())
  description String
  quantity    Int    @default(1)
  price       Float  @default(0)
  total       Float  @default(0)

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model PitchDeck {
  id          String   @id @default(cuid())
  title       String
  clientType  String?
  objective   String?
  sections    String?
  status      String   @default("borrador")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Ebook {
  id          String   @id @default(cuid())
  title       String
  topic       String?
  audience    String?
  structure   String?
  content     String?
  status      String   @default("borrador")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}
