---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BrandLogo from "../../components/BrandLogo.astro";

import {
  getCurrentAdmin,
  loginAdmin,
  userIsAdmin,
} from "../../lib/auth";

import {
  SESSION_COOKIE,
  sessionCookieConfig,
} from "../../lib/session";

export const prerender = false;

let error = "";
const expiredSession =
  Astro.url.searchParams.get("expired") === "1";

const existingSession =
  Astro.cookies.get(SESSION_COOKIE)?.value;

if (Astro.request.method === "GET") {
  const existingUser = await getCurrentAdmin(existingSession);

  if (existingUser) {
    if (userIsAdmin(existingUser)) {
      return Astro.redirect("/admin");
    }

    return Astro.redirect("/dashboard");
  }
}

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const email = String(formData.get("email") || "").trim().toLowerCase();
  const password = String(formData.get("password") || "");
  const result = await loginAdmin(email, password);

  if (!result) {
    error = "Credenciales incorrectas.";
  } else {
    Astro.cookies.set(
      SESSION_COOKIE,
      result.token,
      sessionCookieConfig
    );

    return Astro.redirect("/admin");
  }
}
---

<BaseLayout
  title="Login Admin | NexoraAI"
  description="Acceso interno CRM NexoraAI"
>
  <main class="grid min-h-screen place-items-center bg-[#07070A] px-6 py-16">
    <section class="w-full max-w-md">
      <div class="premium-panel animated-border p-7 md:p-8">
        <BrandLogo label="NexoraAI CRM" markClass="h-8 w-8" textClass="text-sm text-white/70" />

        <div class="mt-10">
          <p class="text-xs uppercase tracking-[0.18em] text-cyan-200/75">
            Acceso seguro
          </p>

          <h1 class="mt-3 text-3xl font-semibold tracking-tight text-white">
            Login Admin
          </h1>

          <p class="mt-3 text-sm leading-relaxed text-white/50">
            Entra para gestionar leads, pipeline, notas y seguimiento comercial.
          </p>
        </div>

        {error && (
          <div class="mt-6 rounded-xl border border-red-300/20 bg-red-500/10 px-4 py-3 text-sm text-red-100">
            {error}
          </div>
        )}

        {!error && expiredSession && (
          <div class="mt-6 rounded-xl border border-amber-300/20 bg-amber-500/10 px-4 py-3 text-sm text-amber-100">
            Tu sesión de prueba ha caducado después de 30 minutos. Inicia sesión de nuevo para continuar.
          </div>
        )}

        <form method="POST" class="mt-7 space-y-4" data-login-form>
          <label class="block space-y-2">
            <span class="text-sm text-white/65">Email</span>
            <input
              type="email"
              name="email"
              autocomplete="email"
              required
              placeholder="admin@nexora.ai"
              class="input-premium w-full"
            />
          </label>

          <label class="block space-y-2">
            <span class="text-sm text-white/65">Contraseña</span>
            <input
              type="password"
              name="password"
              autocomplete="current-password"
              required
              placeholder="••••••••"
              class="input-premium w-full"
            />
          </label>

          <button class="btn-primary w-full py-3.5">
            Entrar al panel
          </button>
        </form>
      </div>
    </section>
  </main>

  <script is:inline>
    (() => {
      const form = document.querySelector("[data-login-form]");

      form?.addEventListener("submit", () => {
        const button = form.querySelector("button");

        if (button) {
          button.disabled = true;
          button.textContent = "Entrando...";
          button.classList.add("opacity-75");
        }
      });
    })();
  </script>
</BaseLayout>
