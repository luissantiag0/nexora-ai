{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/export/leads/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/leads/addNote/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/leads/create/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/leads/list/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/leads/update/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/leads/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/leads/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/pipeline/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}