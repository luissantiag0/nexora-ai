---
const { show = false } = Astro.props;
---

{
  show && (
    <div id="onboarding-overlay" class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm transition-opacity duration-300">
      <div class="mx-4 max-w-lg rounded-2xl border border-white/[0.08] bg-[#07070A] p-8 shadow-[0_40px_100px_-40px_rgba(34,211,238,0.3)] md:p-10">
        <div class="flex h-14 w-14 items-center justify-center rounded-xl border border-cyan-300/20 bg-cyan-300/[0.08] mb-6">
          <svg class="h-7 w-7 text-cyan-200" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <h2 class="text-2xl font-semibold tracking-tight text-white">Bienvenido a AverionAI</h2>
        <p class="mt-3 text-sm leading-relaxed text-white/50">Tu plataforma de CRM, documentos y automatizacion con IA. En los proximos pasos te guiaremos por las funcionalidades principales.</p>
        <div class="mt-8 grid gap-3">
          {[
            { step: "01", label: "Crear tu primer lead", desc: "Anade un contacto y deja que la IA lo clasifique" },
            { step: "02", label: "Explorar el pipeline", desc: "Visualiza y mueve leads entre etapas comerciales" },
            { step: "03", label: "Generar documentos", desc: "Crea facturas, pitch decks e informes con un clic" },
            { step: "04", label: "Automatizar procesos", desc: "Configura flujos automaticos para tus tareas repetitivas" },
          ].map((item) => (
            <div class="flex items-start gap-4 rounded-xl border border-white/[0.06] bg-white/[0.02] px-5 py-4">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-white/[0.08] text-xs font-mono text-white/40">{item.step}</span>
              <div>
                <p class="text-sm font-medium text-white">{item.label}</p>
                <p class="text-xs text-white/40 mt-0.5">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
        <button id="onboarding-start" class="mt-8 w-full rounded-xl bg-white px-6 py-3 text-sm font-semibold text-black transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_16px_40px_-20px_rgba(34,211,238,0.6)] active:translate-y-0">Comenzar recorrido</button>
        <button id="onboarding-skip" class="mt-3 w-full text-center text-xs text-white/30 transition hover:text-white/50">Omitir</button>
      </div>
    </div>
  )
}

<script>
  (() => {
    const overlay = document.getElementById("onboarding-overlay");
    const startBtn = document.getElementById("onboarding-start");
    const skipBtn = document.getElementById("onboarding-skip");

    if (!overlay) return;

    const dismiss = () => {
      overlay.classList.add("opacity-0");
      setTimeout(() => overlay.remove(), 300);
      try { localStorage.setItem("averionai_onboarding_done", "true"); } catch {}
    };

    startBtn?.addEventListener("click", () => {
      dismiss();
      try { localStorage.setItem("averionai_onboarding_done", "true"); } catch {}
    });

    skipBtn?.addEventListener("click", dismiss);
  })();
</script>
