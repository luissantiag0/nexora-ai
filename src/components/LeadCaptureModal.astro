<div
  id="lead-capture-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/70 p-4 backdrop-blur-sm"
  aria-hidden="true"
>
  <div class="w-full max-w-2xl rounded-2xl border border-border-subtle bg-surface-elevated p-6 shadow-2xl md:p-8">
    <div class="flex items-start justify-between gap-4">
      <div>
        <p class="section-eyebrow mb-3">Book your strategy call</p>
        <h3 class="text-2xl font-semibold tracking-tight text-white md:text-3xl">Tell us what you need to automate</h3>
        <p class="mt-3 text-sm leading-relaxed text-text-muted md:text-base">
          Share your goals and current bottlenecks. We will follow up with a tailored automation strategy.
        </p>
      </div>
      <button
        type="button"
        data-close-lead-modal
        class="rounded-lg border border-border-subtle px-3 py-2 text-sm text-text-muted transition hover:border-border-strong hover:text-white"
        aria-label="Close lead form"
      >
        Close
      </button>
    </div>

    <form id="lead-capture-form" class="mt-7 grid gap-4">
      <input type="hidden" name="submittedAt" />
      <input type="text" name="companyWebsite" autocomplete="off" tabindex="-1" class="hidden" />

      <label class="grid gap-2">
        <span class="text-sm font-medium text-white">Full name</span>
        <input
          required
          type="text"
          name="fullName"
          autocomplete="name"
          class="form-input"
          placeholder="Jane Smith"
        />
        <p class="hidden text-xs text-rose-300" data-error-for="fullName"></p>
      </label>

      <label class="grid gap-2">
        <span class="text-sm font-medium text-white">Email</span>
        <input
          required
          type="email"
          name="email"
          autocomplete="email"
          class="form-input"
          placeholder="jane@company.com"
        />
        <p class="hidden text-xs text-rose-300" data-error-for="email"></p>
      </label>

      <label class="grid gap-2">
        <span class="text-sm font-medium text-white">Company name</span>
        <input
          required
          type="text"
          name="companyName"
          autocomplete="organization"
          class="form-input"
          placeholder="Acme Inc."
        />
        <p class="hidden text-xs text-rose-300" data-error-for="companyName"></p>
      </label>

      <label class="grid gap-2">
        <span class="text-sm font-medium text-white">Message / AI need description</span>
        <textarea
          required
          name="message"
          rows="4"
          class="form-input"
          placeholder="We want to automate invoice processing and customer support workflows."
        ></textarea>
        <p class="hidden text-xs text-rose-300" data-error-for="message"></p>
      </label>

      <p id="lead-form-feedback" class="hidden text-sm"></p>

      <div class="mt-2 flex flex-wrap items-center gap-3">
        <button id="lead-form-submit" type="submit" class="btn-primary">Submit request</button>
        <p class="text-xs text-text-muted">We typically respond within one business day.</p>
      </div>
    </form>
  </div>
</div>

<script>
  const modal = document.getElementById("lead-capture-modal");
  const form = document.getElementById("lead-capture-form");
  const submitButton = document.getElementById("lead-form-submit");
  const feedback = document.getElementById("lead-form-feedback");
  const openButtons = document.querySelectorAll("[data-open-lead-modal]");
  const closeButtons = document.querySelectorAll("[data-close-lead-modal]");
  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  const fieldErrors = {
    fullName: "Full name is required.",
    email: "Enter a valid email address.",
    companyName: "Company name is required.",
    message: "Message must be at least 20 characters."
  };

  const getField = (name) => form?.querySelector(`[name="${name}"]`);
  const getErrorNode = (name) => form?.querySelector(`[data-error-for="${name}"]`);

  const setFieldError = (name, message) => {
    const input = getField(name);
    const errorNode = getErrorNode(name);
    if (!input || !errorNode) return;
    if (!message) {
      input.classList.remove("form-input-error");
      errorNode.classList.add("hidden");
      errorNode.textContent = "";
      return;
    }
    input.classList.add("form-input-error");
    errorNode.classList.remove("hidden");
    errorNode.textContent = message;
  };

  const validatePayload = (payload) => {
    const errors = {};
    if (!payload.fullName) errors.fullName = fieldErrors.fullName;
    if (!payload.companyName) errors.companyName = fieldErrors.companyName;
    if (!emailRegex.test(payload.email)) errors.email = fieldErrors.email;
    if (payload.message.length < 20) errors.message = fieldErrors.message;
    return errors;
  };

  const openModal = () => {
    if (!modal) return;
    const submittedAt = form?.querySelector('[name="submittedAt"]');
    if (submittedAt) submittedAt.value = String(Date.now());
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    modal.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  };

  const closeModal = () => {
    if (!modal) return;
    modal.classList.add("hidden");
    modal.classList.remove("flex");
    modal.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  };

  openButtons.forEach((button) => {
    button.addEventListener("click", (event) => {
      event.preventDefault();
      openModal();
    });
  });

  closeButtons.forEach((button) => {
    button.addEventListener("click", closeModal);
  });

  modal?.addEventListener("click", (event) => {
    if (event.target === modal) {
      closeModal();
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && modal?.getAttribute("aria-hidden") === "false") {
      closeModal();
    }
  });

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!form || !submitButton || !feedback) return;

    const formData = new FormData(form);
    const payload = {
      fullName: String(formData.get("fullName") || "").trim(),
      email: String(formData.get("email") || "").trim(),
      companyName: String(formData.get("companyName") || "").trim(),
      message: String(formData.get("message") || "").trim(),
      companyWebsite: String(formData.get("companyWebsite") || "").trim(),
      submittedAt: String(formData.get("submittedAt") || "")
    };

    const errors = validatePayload(payload);
    setFieldError("fullName", errors.fullName);
    setFieldError("email", errors.email);
    setFieldError("companyName", errors.companyName);
    setFieldError("message", errors.message);
    if (Object.keys(errors).length > 0) return;

    submitButton.disabled = true;
    submitButton.textContent = "Submitting request...";
    feedback.classList.add("hidden");

    try {
      const response = await fetch("/api/lead", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify(payload)
      });

      const result = await response.json();

      if (!response.ok) {
        throw new Error(result?.message || "Submission failed.");
      }

      feedback.textContent = "Thanks, your request was received. We will contact you shortly.";
      feedback.className = "text-sm text-emerald-300";
      form.reset();
      const submittedAt = form.querySelector('[name="submittedAt"]');
      if (submittedAt) submittedAt.value = String(Date.now());
    } catch (error) {
      feedback.textContent = error instanceof Error ? error.message : "Something went wrong. Please try again.";
      feedback.className = "text-sm text-rose-300";
    } finally {
      feedback.classList.remove("hidden");
      submitButton.disabled = false;
      submitButton.textContent = "Submit request";
    }
  });

  ["fullName", "email", "companyName", "message"].forEach((name) => {
    const field = getField(name);
    field?.addEventListener("input", () => {
      const payload = {
        fullName: String(getField("fullName")?.value || "").trim(),
        email: String(getField("email")?.value || "").trim(),
        companyName: String(getField("companyName")?.value || "").trim(),
        message: String(getField("message")?.value || "").trim()
      };
      const errors = validatePayload(payload);
      setFieldError(name, errors[name]);
    });
  });
</script>
