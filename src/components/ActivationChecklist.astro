---
const { totalLeads = 0, totalDocuments = 0 } = Astro.props;
const items = [
  { label: "Crear tu primer lead", key: "lead", done: totalLeads >= 1 },
  { label: "Explorar el pipeline", key: "pipeline", done: false },
  { label: "Generar tu primer documento", key: "document", done: totalDocuments >= 1 },
  { label: "Mover un lead en el pipeline", key: "move", done: false },
  { label: "Configurar tu primer workflow", key: "workflow", done: false },
];
const completed = items.filter((i) => i.done).length;
const total = items.length;
---

{completed < total && (
  <div class="premium-panel p-5 md:p-6" data-reveal>
    <div class="flex items-center justify-between mb-4">
      <div>
        <h2 class="text-lg font-semibold text-white">Activacion</h2>
        <p class="text-sm text-white/45 mt-1">Completa los pasos para empezar con AverionAI.</p>
      </div>
      <span class="text-xs text-white/40">{completed}/{total}</span>
    </div>
    <div class="h-1.5 overflow-hidden rounded-full bg-white/10 mb-5">
      <span class="block h-full rounded-full bg-gradient-to-r from-cyan-300 to-emerald-300 transition-all duration-500" style={`width: ${(completed / total) * 100}%`}></span>
    </div>
    <div class="grid gap-3">
      {items.map((item, i) => {
        const isCompleted = item.done;
        return (
          <div class={`flex items-center gap-3 rounded-xl border px-4 py-3 transition-all duration-300 ${isCompleted ? "border-emerald-300/20 bg-emerald-300/[0.04]" : "border-white/[0.06] bg-white/[0.02]"}`}>
            <span class={`flex h-6 w-6 shrink-0 items-center justify-center rounded-full text-xs font-bold transition-all duration-300 ${isCompleted ? "bg-emerald-400/20 text-emerald-300" : "border border-white/[0.15] text-white/30"}`}>
              {isCompleted ? "✓" : i + 1}
            </span>
            <span class={`text-sm ${isCompleted ? "text-emerald-200/70 line-through" : "text-white/60"}`}>{item.label}</span>
          </div>
        );
      })}
    </div>
  </div>
)}
