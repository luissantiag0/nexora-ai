---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import LeadCaptureModal from "../components/LeadCaptureModal.astro";

export const prerender = false;
---

<BaseLayout title="AverionAI ya está aquí | Automatización con IA" description="Lanzamos AverionAI: CRM inteligente, automatización con IA, facturación y documentos en una plataforma SaaS moderna.">
  <Navbar />
  <main class="min-h-screen bg-[#07070A]">
    <section class="relative overflow-hidden border-b border-white/10 pb-20 pt-20 md:pb-28 md:pt-28">
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(34,211,238,0.12),transparent_60%)]"></div>
      <div class="container text-center" data-reveal>
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl border border-cyan-300/20 bg-cyan-300/10 shadow-[0_0_40px_-8px_rgba(34,211,238,0.3)]">
          <span class="text-3xl icon-pulse-soft">🚀</span>
        </div>
        <h1 class="mt-6 text-5xl font-semibold tracking-tight text-white md:text-7xl">AverionAI ya está aquí</h1>
        <p class="mx-auto mt-5 max-w-2xl text-lg text-white/60">La plataforma de automatización con IA que transforma la gestión de leads, documentos y procesos comerciales.</p>
        <div class="mt-10 flex flex-wrap justify-center gap-4">
          <a href="/register" class="btn-primary px-8 py-3 text-base">Empezar gratis</a>
          <a href="/pricing" class="btn-secondary px-8 py-3 text-base">Ver planes</a>
        </div>
      </div>
    </section>

    <section class="container py-20 md:py-24">
      <h2 class="text-center text-3xl font-semibold text-white md:text-4xl" data-reveal>Qué hemos construido</h2>
      <div class="mt-14 grid gap-6 md:grid-cols-3">
        {[
          { icon: "🤖", title: "CRM inteligente", desc: "Gestiona leads con clasificación automática por IA, pipeline visual y seguimiento automatizado." },
          { icon: "📄", title: "Documentación IA", desc: "Genera facturas, pitch decks, informes y ebooks profesionales con un clic." },
          { icon: "⚡", title: "Automatización", desc: "Workflows automáticos, recordatorios, emails y acciones inteligentes sin código." },
          { icon: "📊", title: "Analítica", desc: "Métricas de conversión, pipeline, actividad y forecasting basado en datos reales." },
          { icon: "🔒", title: "SSR seguro", desc: "Autenticación, sesiones protegidas, CSRF, rate limiting y auditoría completa." },
          { icon: "🎯", title: "IA avanzada", desc: "Scoring, predicción, análisis de sentimiento y generación de contenido con IA." },
        ].map((f, i) => (
          <div class="card-premium-hover p-6" data-reveal data-delay={i * 80}>
            <span class="text-3xl icon-float" style="animation-delay:{i * 0.2}s">{f.icon}</span>
            <h3 class="mt-4 text-lg font-semibold text-white">{f.title}</h3>
            <p class="mt-2 text-sm text-white/60">{f.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="border-t border-white/10 bg-white/[0.02] py-20">
      <div class="container text-center">
        <h2 class="text-3xl font-semibold text-white" data-reveal>Prueba gratuita de 30 minutos</h2>
        <p class="mt-4 text-white/60">Sin tarjeta de crédito. Acceso completo a todas las funciones premium.</p>
        <a href="/register" class="btn-primary mt-8 inline-flex px-8 py-3 text-base">Comenzar ahora</a>
      </div>
    </section>
  </main>
  <Footer />
  <LeadCaptureModal />
</BaseLayout>
