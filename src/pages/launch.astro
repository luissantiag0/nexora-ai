---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const features = [
  "CRM con clasificacion de leads impulsada por IA y gestion de pipeline",
  "Generacion profesional de documentos (facturas, pitch decks, ebooks, informes)",
  "Flujos de trabajo automatizados y disparadores de correo",
  "Analitica en tiempo real y prevision de conversion",
  "Arquitectura SSR para seguridad y rendimiento",
  "Integracion con Stripe para gestion de suscripciones",
  "Acceso basado en roles para colaboracion en equipo (plan Business)",
];

const benefits = [
  "Reduce el tiempo de respuesta a leads de horas a minutos con clasificacion IA",
  "Genera documentos profesionales en segundos en lugar de horas",
  "Elimina la entrada manual de datos con flujos automatizados",
  "Toma decisiones basadas en datos con analitica de pipeline en tiempo real",
  "Implementa con confianza: cada pagina se renderiza en servidor y es segura",
];

const faq = [
  { q: "Que hace diferente a AverionAI de otros CRM?", a: "AverionAI esta construido desde cero con IA en el nucleo, no como un anadido. La generacion de documentos, clasificacion de leads y creacion de contenido son funcionalidades nativas." },
  { q: "Mis datos estan seguros?", a: "AverionAI utiliza arquitectura SSR, sesiones cifradas, proteccion CSRF, limitacion de tasa y auditoria completa." },
  { q: "Puedo probar antes de comprar?", a: "Ofrecemos una prueba gratuita de 30 minutos con acceso completo. No requiere tarjeta de credito." },
  { q: "Que pasa cuando termina mi prueba?", a: "Tu cuenta permanece activa. Pierdes acceso a funciones premium hasta que te suscribas. Tus datos nunca se eliminan." },
];

const growthPlan = [
  { week: "Semana 1", title: "Fundacion", items: ["Publicar 2 articulos SEO en el blog", "Compartir AverionAI en LinkedIn", "Grabar y publicar video demo de 30 segundos", "Monitorear pagina /status"] },
  { week: "Semana 2", title: "Contenido", items: ["Publicar 2 articulos (CRM, automatizacion)", "Compartir mini tutoriales en LinkedIn", "Actualizar /changelog con nuevas versiones"] },
  { week: "Semana 3", title: "Comunidad", items: ["Publicar en Indie Hackers y Reddit", "Lanzar programa de referidos con descuentos", "Recopilar feedback y priorizar mejoras"] },
  { week: "Semana 4", title: "Optimizacion", items: ["Prueba A/B del hero de la landing", "Prueba A/B del CTA en pricing", "Analisis del embudo de conversion", "Enviar secuencia de onboarding a nuevos usuarios"] },
];

const checklist = [
  "Pagina /launch lista con diseno premium",
  "Pagina /pricing con planes Free, Premium y Business",
  "Pagina /roadmap con 4 secciones",
  "Pagina /changelog con 10 versiones",
  "Pagina /status con 8 servicios",
  "Integracion Stripe preparada",
  "Blog SEO con articulos y categorias",
  "Sitemap.xml con todas las rutas",
  "Schema.org Organization y SoftwareApplication",
  "OpenGraph, Twitter cards y JSON-LD",
  "Rate limiting y sanitizacion de entrada",
  "Healthcheck endpoint en /api/health",
];
---

<BaseLayout title="Lanzamiento AverionAI | CRM y Documentos con IA" description="Lanzamiento oficial de AverionAI: plataforma SaaS con CRM, documentos y automatizacion impulsada por IA.">
  <Navbar />
  <main class="min-h-screen bg-[#07070A]">
    <section class="relative overflow-hidden pb-20 pt-20 md:pb-28 md:pt-28">
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_30%_20%,rgba(34,211,238,0.08),transparent_50%),radial-gradient(ellipse_at_70%_80%,rgba(16,185,129,0.06),transparent_50%)]"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-cyan-300/50 to-transparent"></div>
      <div class="container relative">
        <div class="mx-auto max-w-4xl text-center" data-reveal>
          <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-1.5 text-xs font-medium tracking-wider text-white/50 uppercase">Lanzamiento oficial</span>
          <h1 class="mt-6 text-5xl font-semibold leading-[1.05] tracking-tight text-white md:text-7xl">AverionAI<span class="text-cyan-200/60"> —</span><br /><span class="bg-gradient-to-r from-white via-cyan-100 to-emerald-100 bg-clip-text text-transparent">CRM y documentos con IA</span></h1>
          <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-white/50 md:text-xl">CRM impulsado por IA, generacion de documentos y automatizacion para empresas modernas.</p>
          <div class="mt-10 flex flex-wrap justify-center gap-4">
            <a href="/register" class="group inline-flex items-center gap-2 rounded-xl bg-white px-8 py-3.5 text-sm font-semibold text-black shadow-[0_18px_45px_-26px_rgba(255,255,255,0.9)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_24px_70px_-28px_rgba(34,211,238,0.9)]">Probar gratis<span class="transition-transform group-hover:translate-x-1">→</span></a>
            <a href="/pricing" class="inline-flex items-center rounded-xl border border-white/15 bg-white/[0.02] px-8 py-3.5 text-sm font-semibold text-white transition-all duration-300 hover:-translate-y-0.5 hover:border-cyan-300/40 hover:bg-cyan-300/10 hover:text-cyan-100">Ver planes</a>
          </div>
        </div>
      </div>
    </section>

    <section class="border-t border-white/[0.06] py-24 md:py-28">
      <div class="container">
        <div class="mx-auto grid max-w-5xl gap-12 md:grid-cols-2 md:items-center">
          <div data-reveal>
            <span class="inline-flex items-center rounded-full border border-cyan-300/20 bg-cyan-300/[0.06] px-3 py-1 text-xs font-medium tracking-wider text-cyan-200/80 uppercase">Que es</span>
            <h2 class="mt-5 text-3xl font-semibold tracking-tight text-white md:text-5xl">Que es AverionAI</h2>
          </div>
          <div class="text-sm leading-relaxed text-white/50 space-y-4" data-reveal data-delay="100">
            <p>AverionAI es una plataforma SaaS que integra CRM, generacion de documentos con IA, facturacion automatizada y analitica de negocio en un entorno seguro.</p>
            <p>A diferencia de los CRM tradicionales que requieren semanas de configuracion, AverionAI funciona de inmediato. Crea leads, clasificalos con IA, genera facturas y pitch decks profesionales, y realiza seguimiento de tu pipeline desde una unica interfaz renderizada en servidor.</p>
            <p>Construido con Astro SSR, Prisma y Stripe, AverionAI ofrece seguridad de nivel empresarial sin complejidad. Cada pagina se renderiza en servidor. Las sesiones estan protegidas. Los datos permanecen cifrados.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="border-t border-white/[0.06] bg-white/[0.015] py-24 md:py-28">
      <div class="container">
        <div class="mx-auto max-w-3xl text-center" data-reveal>
          <span class="inline-flex items-center rounded-full border border-cyan-300/20 bg-cyan-300/[0.06] px-3 py-1 text-xs font-medium tracking-wider text-cyan-200/80 uppercase">Funcionalidades</span>
          <h2 class="mt-5 text-3xl font-semibold tracking-tight text-white md:text-5xl">Caracteristicas clave</h2>
        </div>
        <div class="mt-16 grid gap-px overflow-hidden rounded-2xl border border-white/[0.06] bg-white/[0.06] md:grid-cols-2">
          {features.map((f, i) => (
            <div class="bg-[#07070A] p-6 transition-all duration-300 hover:bg-white/[0.02] md:p-8" data-reveal data-delay={i * 60}>
              <span class="text-xs font-mono text-cyan-200/40">{(i + 1).toString().padStart(2, "0")}</span>
              <p class="mt-3 text-sm text-white/80">{f}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-t border-white/[0.06] py-24 md:py-28">
      <div class="container">
        <div class="mx-auto max-w-3xl text-center" data-reveal>
          <span class="inline-flex items-center rounded-full border border-emerald-300/20 bg-emerald-300/[0.06] px-3 py-1 text-xs font-medium tracking-wider text-emerald-200/80 uppercase">Beneficios</span>
          <h2 class="mt-5 text-3xl font-semibold tracking-tight text-white md:text-5xl">Por que los equipos eligen AverionAI</h2>
        </div>
        <div class="mt-16 mx-auto grid max-w-4xl gap-4 md:grid-cols-2">
          {benefits.map((b, i) => (
            <div class="flex items-start gap-4 rounded-xl border border-white/[0.06] bg-white/[0.02] p-5 transition-all duration-300 hover:-translate-y-0.5 hover:border-emerald-300/20" data-reveal data-delay={i * 80}>
              <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-emerald-400/20 text-emerald-300 text-xs font-bold">✓</span>
              <span class="text-sm text-white/70">{b}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-t border-white/[0.06] bg-white/[0.015] py-24 md:py-28">
      <div class="container">
        <div class="mx-auto max-w-3xl text-center" data-reveal>
          <span class="inline-flex items-center rounded-full border border-cyan-300/20 bg-cyan-300/[0.06] px-3 py-1 text-xs font-medium tracking-wider text-cyan-200/80 uppercase">Product Hunt</span>
          <h2 class="mt-5 text-3xl font-semibold tracking-tight text-white md:text-5xl">Lanzamiento en Product Hunt</h2>
          <p class="mt-4 text-base text-white/50">Sigue nuestro lanzamiento y se el primero en enterarte.</p>
          <a href="/register" class="btn-secondary mt-6 inline-flex px-6 py-2.5 text-sm">Seguir lanzamiento</a>
        </div>
        <div class="mt-16 mx-auto grid max-w-4xl gap-6 md:grid-cols-2">
          <div class="rounded-xl border border-white/[0.06] bg-white/[0.02] p-6" data-reveal><span class="text-xs font-semibold text-cyan-200/60 uppercase tracking-wider">Tagline</span><p class="mt-3 text-sm text-white/70">AI-powered CRM, documents, and automation for modern businesses.</p></div>
          <div class="rounded-xl border border-white/[0.06] bg-white/[0.02] p-6" data-reveal data-delay="60"><span class="text-xs font-semibold text-cyan-200/60 uppercase tracking-wider">Descripcion corta</span><p class="mt-3 text-sm text-white/70">AverionAI combina CRM, generacion de documentos, facturacion y automatizacion con IA en una plataforma SaaS segura con SSR.</p></div>
          <div class="rounded-xl border border-white/[0.06] bg-white/[0.02] p-6 md:col-span-2" data-reveal data-delay="120"><span class="text-xs font-semibold text-cyan-200/60 uppercase tracking-wider">Descripcion larga</span><p class="mt-3 text-sm text-white/70 leading-relaxed">AverionAI es una plataforma SaaS que integra CRM, generacion de documentos con IA, facturacion automatizada y analitica de negocio. Construido con Astro SSR, Prisma y Stripe, ofrece seguridad de nivel empresarial sin complejidad.</p></div>
          <div class="rounded-xl border border-white/[0.06] bg-white/[0.02] p-6 md:col-span-2" data-reveal data-delay="180"><span class="text-xs font-semibold text-cyan-200/60 uppercase tracking-wider">Comentario del creador</span><p class="mt-3 text-sm text-white/50 leading-relaxed italic">Soy Luis, fundador de AverionAI. Durante las ultimas semanas he construido una plataforma SaaS completa desde cero: CRM, generacion de documentos, integracion de IA, facturacion con Stripe y arquitectura renderizada en servidor, todo con Astro SSR, Prisma y PostgreSQL. AverionAI nace de una observacion simple: la mayoria de los CRM son demasiado basicos o demasiado complejos. Queriamos una plataforma donde la IA sea parte de los cimientos, accesible desde el primer dia.</p></div>
          <div class="rounded-xl border border-white/[0.06] bg-white/[0.02] p-6 md:col-span-2" data-reveal data-delay="240"><span class="text-xs font-semibold text-cyan-200/60 uppercase tracking-wider">FAQ</span><div class="mt-4 grid gap-4">{faq.map((item) => (<div><p class="text-sm font-medium text-white/80">{item.q}</p><p class="mt-1 text-sm text-white/50">{item.a}</p></div>))}</div></div>
        </div>
      </div>
    </section>

    <section class="border-t border-white/[0.06] py-24 md:py-28">
      <div class="container">
        <div class="mx-auto max-w-3xl text-center" data-reveal>
          <span class="inline-flex items-center rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-xs font-medium tracking-wider text-white/50 uppercase">Capturas</span>
          <h2 class="mt-5 text-3xl font-semibold tracking-tight text-white md:text-5xl">Proximamente</h2>
          <p class="mt-4 text-base text-white/50">Los recursos visuales se agregaran antes del lanzamiento.</p>
        </div>
        <div class="mt-16 mx-auto grid max-w-3xl gap-6 md:grid-cols-2">
          <div class="flex aspect-video items-center justify-center rounded-xl border border-dashed border-white/[0.08] bg-white/[0.01] text-sm text-white/30" data-reveal>Dashboard: pipeline CRM</div>
          <div class="flex aspect-video items-center justify-center rounded-xl border border-dashed border-white/[0.08] bg-white/[0.01] text-sm text-white/30" data-reveal data-delay="80">Generador de documentos</div>
        </div>
      </div>
    </section>

    <section class="border-t border-white/[0.06] bg-white/[0.015] py-24 md:py-28">
      <div class="container">
        <div class="mx-auto max-w-3xl text-center" data-reveal>
          <span class="inline-flex items-center rounded-full border border-cyan-300/20 bg-cyan-300/[0.06] px-3 py-1 text-xs font-medium tracking-wider text-cyan-200/80 uppercase">LinkedIn</span>
          <h2 class="mt-5 text-3xl font-semibold tracking-tight text-white md:text-5xl">Lanzamiento en LinkedIn</h2>
        </div>
        <div class="mt-16 mx-auto grid max-w-4xl gap-6">
          <div class="rounded-xl border border-white/[0.06] bg-white/[0.02] p-6 md:p-8" data-reveal><span class="text-xs font-semibold text-cyan-200/60 uppercase tracking-wider">Post personal</span><p class="mt-3 text-sm text-white/60 leading-relaxed">He pasado las ultimas semanas construyendo AverionAI desde cero: una plataforma SaaS completa de CRM, generacion de documentos y automatizacion con IA. Sin plantillas. Sin atajos. Solo Astro SSR, Prisma, PostgreSQL y Stripe. El resultado: una plataforma donde la clasificacion de leads con IA, la generacion profesional de documentos y los flujos automatizados trabajan juntos en un entorno seguro renderizado en servidor.</p></div>
          <div class="rounded-xl border border-white/[0.06] bg-white/[0.02] p-6 md:p-8" data-reveal data-delay="80"><span class="text-xs font-semibold text-cyan-200/60 uppercase tracking-wider">Post de empresa</span><p class="mt-3 text-sm text-white/60 leading-relaxed">AverionAI ya esta disponible. Una plataforma nativa en IA para gestion de leads, generacion de documentos y automatizacion empresarial. Creada para equipos que necesitan herramientas inteligentes sin complejidad empresarial. Prueba gratuita de 30 minutos en averionai.co.in.</p></div>
        </div>
      </div>
    </section>

    <section class="border-t border-white/[0.06] py-24 md:py-28">
      <div class="container">
        <div class="mx-auto max-w-3xl text-center" data-reveal>
          <span class="inline-flex items-center rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-xs font-medium tracking-wider text-white/50 uppercase">Publicidad</span>
          <h2 class="mt-5 text-3xl font-semibold tracking-tight text-white md:text-5xl">Campanas publicitarias</h2>
          <p class="mt-4 text-base text-white/50">Estructura preparada para cada plataforma. Sin activar.</p>
        </div>
        <div class="mt-16 mx-auto grid max-w-4xl gap-4 md:grid-cols-2">
          {[{ t: "Google Ads", d: "10 palabras clave, 3 anuncios, 2 extensiones" },{ t: "Meta Ads", d: "3 creatividades, segmentacion B2B" },{ t: "TikTok Ads", d: "2 scripts de 15 segundos" },{ t: "LinkedIn Ads", d: "2 anuncios, segmentacion para decision makers B2B" }].map((ad, i) => (
            <div class="rounded-xl border border-white/[0.06] bg-white/[0.02] p-6" data-reveal data-delay={i * 80}>
              <span class="text-sm font-semibold text-white">{ad.t}</span>
              <p class="mt-2 text-sm text-white/50">{ad.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-t border-white/[0.06] py-24 md:py-28">
      <div class="container">
        <div class="mx-auto max-w-3xl text-center" data-reveal>
          <span class="inline-flex items-center rounded-full border border-emerald-300/20 bg-emerald-300/[0.06] px-3 py-1 text-xs font-medium tracking-wider text-emerald-200/80 uppercase">Crecimiento</span>
          <h2 class="mt-5 text-3xl font-semibold tracking-tight text-white md:text-5xl">Plan de crecimiento 30 dias</h2>
        </div>
        <div class="mt-16 mx-auto grid max-w-4xl gap-6 md:grid-cols-2">
          {growthPlan.map((w, i) => (
            <div class="rounded-xl border border-white/[0.06] bg-white/[0.02] p-6" data-reveal data-delay={i * 80}>
              <span class="text-xs font-semibold text-emerald-200/60 uppercase tracking-wider">{w.week}</span>
              <h3 class="mt-2 text-lg font-semibold text-white">{w.title}</h3>
              <ul class="mt-4 grid gap-2">{w.items.map((item) => (<li class="flex items-start gap-2 text-sm text-white/60"><span class="mt-1.5 h-1 w-1 shrink-0 rounded-full bg-emerald-400/50"></span>{item}</li>))}</ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-t border-white/[0.06] bg-white/[0.015] py-24 md:py-28">
      <div class="container">
        <div class="mx-auto max-w-3xl text-center" data-reveal>
          <span class="inline-flex items-center rounded-full border border-cyan-300/20 bg-cyan-300/[0.06] px-3 py-1 text-xs font-medium tracking-wider text-cyan-200/80 uppercase">Checklist</span>
          <h2 class="mt-5 text-3xl font-semibold tracking-tight text-white md:text-5xl">Checklist de lanzamiento</h2>
        </div>
        <div class="mt-16 mx-auto grid max-w-4xl gap-3 md:grid-cols-2">
          {checklist.map((item, i) => (
            <div class="flex items-start gap-3 rounded-xl border border-white/[0.06] bg-white/[0.02] px-5 py-3 transition-all duration-300 hover:border-cyan-300/20" data-reveal data-delay={i * 40}>
              <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full border border-white/[0.15] text-xs text-white/30">{(i + 1).toString().padStart(2, "0")}</span>
              <span class="text-sm text-white/60">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-t border-white/[0.06] py-24">
      <div class="container">
        <div class="mx-auto max-w-3xl rounded-2xl border border-white/[0.06] bg-gradient-to-b from-white/[0.03] to-transparent p-10 text-center md:p-14" data-reveal>
          <span class="inline-flex items-center rounded-full border border-cyan-300/20 bg-cyan-300/[0.06] px-3 py-1 text-xs font-medium tracking-wider text-cyan-200/80 uppercase">Empieza ahora</span>
          <h2 class="mt-6 text-3xl font-semibold tracking-tight text-white md:text-4xl">Prueba AverionAI gratis</h2>
          <p class="mt-4 text-base text-white/50">30 minutos de acceso premium completo. Sin tarjeta. Sin riesgo.</p>
          <a href="/register" class="mt-8 inline-flex items-center gap-2 rounded-xl bg-white px-8 py-3.5 text-sm font-semibold text-black shadow-[0_18px_45px_-26px_rgba(255,255,255,0.9)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_24px_70px_-28px_rgba(34,211,238,0.9)]">Crear cuenta gratis</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
