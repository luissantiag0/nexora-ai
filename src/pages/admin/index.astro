---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ui } from "../../lib/uiClasses";
import {
  LEAD_STATUSES,
  addLeadNote,
  getSuggestedNextAction,
  getSuggestedOutreachMessage,
  readLeads,
  updateLeadStatus,
  type LeadStatus,
} from "../../lib/leadStorage";

export const prerender = false;

/* =========================
   AUTENTICACIÓN ADMIN
========================= */

const LOGIN_WINDOW_MS = 15 * 60 * 1000;
const MAX_LOGIN_ATTEMPTS = 6;
const loginAttemptsByIp = new Map();

const readEnv = (key: string): string => {
  const fromProcess =
    typeof globalThis !== "undefined" && "process" in globalThis
      ? globalThis.process?.env?.[key]
      : undefined;

  const fromMeta = import.meta.env[key];

  return (fromProcess ?? fromMeta ?? "").trim();
};

const adminPassword = readEnv("ADMIN_PASSWORD") || "admin";
const cookieName = "nexora_admin_auth";

const existingCookie = Astro.cookies.get(cookieName)?.value;
let isAuthed = existingCookie === "1";

let authError = "";
let actionMessage = "";

/* =========================
   TRADUCCIÓN ESTADOS
========================= */

const statusLabels = {
  new: "Nuevo",
  contacted: "Contactado",
  qualified: "Calificado",
  proposal_sent: "Propuesta enviada",
  closed_won: "Ganado",
  closed_lost: "Perdido",
};

const statusBadgeClass = {
  new: "border border-sky-400/30 bg-sky-500/10 text-sky-200",
  contacted: "border border-amber-400/30 bg-amber-500/10 text-amber-200",
  qualified: "border border-emerald-400/30 bg-emerald-500/10 text-emerald-200",
  proposal_sent: "border border-purple-400/30 bg-purple-500/10 text-purple-200",
  closed_won: "border border-green-400/30 bg-green-500/10 text-green-200",
  closed_lost: "border border-rose-400/30 bg-rose-500/10 text-rose-200",
};

const statusButtonClass = statusBadgeClass;

/* =========================
   FILTRO
========================= */

const url = new URL(Astro.request.url);
const filter = url.searchParams.get("status") || "all";

/* =========================
   POST ACTIONS
========================= */

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const intent = formData.get("intent");

  if (intent === "login" && !isAuthed) {
    const password = String(formData.get("password") || "");

    if (password === adminPassword) {
      Astro.cookies.set(cookieName, "1", {
        httpOnly: true,
        sameSite: "lax",
        path: "/",
        maxAge: 60 * 60 * 8,
      });

      isAuthed = true;
      actionMessage = "Acceso concedido al panel.";
    } else {
      authError = "Contraseña incorrecta.";
    }
  }

  if (intent === "update-status") {
    const leadId = String(formData.get("leadId") || "");
    const status = String(formData.get("status") || "");

    await updateLeadStatus(leadId, status);
    actionMessage = "Estado actualizado correctamente.";
  }

  if (intent === "add-note") {
    const leadId = String(formData.get("leadId") || "");
    const note = String(formData.get("note") || "");

    await addLeadNote(leadId, note);
    actionMessage = "Nota añadida correctamente.";
  }
}

const leads = isAuthed ? await readLeads() : [];
---

<BaseLayout
  title="NexoraAI Admin | Leads"
  description="Panel interno de leads"
>
  <main class={ui.section}>
    <div class={ui.pageShell}>

      <h1 class="text-3xl font-semibold text-white">
        Panel de Leads
      </h1>

      <p class="text-white/60 mt-2">
        CRM interno de NexoraAI
      </p>

      {authError && (
        <p class="text-red-400 mt-3">{authError}</p>
      )}

      {!isAuthed ? (
        <form method="POST" class="mt-8 max-w-sm">
          <input type="hidden" name="intent" value="login" />

          <input
            type="password"
            name="password"
            placeholder="Contraseña admin"
            class="w-full p-3 rounded bg-white/5 text-white"
          />

          <button class="mt-4 w-full bg-white text-black py-3 rounded">
            Entrar
          </button>
        </form>
      ) : (
        <div class="mt-10">

          {actionMessage && (
            <p class="text-green-300 mb-4">{actionMessage}</p>
          )}

          {/* LISTA LEADS */}
          <div class="space-y-6">

            {leads.map((lead) => (
              <article class="border border-white/10 bg-white/5 p-5 rounded-xl">

                <div class="flex justify-between">
                  <h3 class="text-white font-semibold">
                    {lead.name}
                  </h3>

                  <span class={`text-xs px-2 py-1 rounded ${statusBadgeClass[lead.status]}`}>
                    {statusLabels[lead.status]}
                  </span>
                </div>

                <p class="text-white/60 text-sm mt-2">
                  {lead.email}
                </p>

                <p class="text-white/60 mt-3">
                  {lead.message}
                </p>

                <p class="text-xs text-white/40 mt-2">
                  {new Date(lead.timestamp).toLocaleString("es-ES")}
                </p>

                {/* cambiar estado */}
                <form method="POST" class="mt-4 flex gap-2">
                  <input type="hidden" name="intent" value="update-status" />
                  <input type="hidden" name="leadId" value={lead.id} />

                  <select name="status" class="bg-black/40 p-2 rounded text-white">
                    {Object.keys(statusLabels).map((s) => (
                      <option value={s} selected={lead.status === s}>
                        {statusLabels[s]}
                      </option>
                    ))}
                  </select>

                  <button class="bg-white text-black px-3 rounded">
                    Actualizar
                  </button>
                </form>

                {/* notas */}
                <form method="POST" class="mt-3 flex gap-2">
                  <input type="hidden" name="intent" value="add-note" />
                  <input type="hidden" name="leadId" value={lead.id} />

                  <input
                    name="note"
                    placeholder="Añadir nota interna"
                    class="w-full p-2 rounded bg-white/5 text-white"
                  />

                  <button class="bg-white text-black px-3 rounded">
                    Añadir
                  </button>
                </form>

              </article>
            ))}

          </div>

        </div>
      )}

    </div>
  </main>
</BaseLayout>