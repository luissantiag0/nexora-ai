---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  LEAD_STATUSES,
  addLeadNote,
  getSuggestedNextAction,
  getSuggestedOutreachMessage,
  readLeads,
  updateLeadStatus,
  type LeadStatus
} from "../../lib/leadStorage";

export const prerender = false;
const LOGIN_WINDOW_MS = 15 * 60 * 1000;
const MAX_LOGIN_ATTEMPTS = 6;
const loginAttemptsByIp = new Map<string, { count: number; resetAt: number }>();

const readEnv = (key: string): string => {
  const fromProcess = typeof process !== "undefined" ? process.env?.[key] : undefined;
  const fromMeta = (import.meta.env[key] as string | undefined) ?? undefined;
  return (fromProcess ?? fromMeta ?? "").trim();
};

const adminPassword = readEnv("ADMIN_PASSWORD") || "admin";
const usingDevPasswordFallback = !readEnv("ADMIN_PASSWORD");
const cookieName = "nexora_admin_auth";
const existingCookie = Astro.cookies.get(cookieName)?.value;
const hasValidSession = Boolean(adminPassword) && existingCookie === "1";
let isAuthed = hasValidSession;
let authError = "";
let actionMessage = "";

const statusLabels: Record<LeadStatus, string> = {
  new: "New",
  contacted: "Contacted",
  qualified: "Qualified",
  proposal_sent: "Proposal Sent",
  closed_won: "Closed Won",
  closed_lost: "Closed Lost"
};

const statusBadgeClass: Record<LeadStatus, string> = {
  new: "border-sky-500/40 bg-sky-500/10 text-sky-300",
  contacted: "border-amber-500/40 bg-amber-500/10 text-amber-300",
  qualified: "border-emerald-500/40 bg-emerald-500/10 text-emerald-300",
  proposal_sent: "border-purple-500/40 bg-purple-500/10 text-purple-300",
  closed_won: "border-green-700/50 bg-green-700/20 text-green-200",
  closed_lost: "border-rose-500/30 bg-rose-500/10 text-rose-300"
};

const url = new URL(Astro.request.url);
const filterFromQuery = String(url.searchParams.get("status") ?? "").trim();
const selectedStatusFilter = (LEAD_STATUSES as readonly string[]).includes(filterFromQuery)
  ? (filterFromQuery as LeadStatus)
  : "all";
const clientIp =
  Astro.request.headers.get("x-forwarded-for")?.split(",")[0]?.trim() ||
  Astro.request.headers.get("x-real-ip")?.trim() ||
  "unknown";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const intent = String(formData.get("intent") ?? "login");

  if (intent === "login" && !hasValidSession) {
    const now = Date.now();
    const attempts = loginAttemptsByIp.get(clientIp);
    if (attempts && now <= attempts.resetAt && attempts.count >= MAX_LOGIN_ATTEMPTS) {
      authError = "Too many login attempts. Try again later.";
    } else {
    const submittedPassword = String(formData.get("password") ?? "");
    if (!adminPassword) {
      authError = "ADMIN_PASSWORD is not configured.";
    } else if (submittedPassword === adminPassword) {
      loginAttemptsByIp.delete(clientIp);
      Astro.cookies.set(cookieName, "1", {
        httpOnly: true,
        sameSite: "lax",
        secure: import.meta.env.PROD,
        path: "/",
        maxAge: 60 * 60 * 8
      });
      isAuthed = true;
      actionMessage = "Dashboard unlocked.";
    } else {
      const nextCount = attempts && now <= attempts.resetAt ? attempts.count + 1 : 1;
      loginAttemptsByIp.set(clientIp, {
        count: nextCount,
        resetAt: now + LOGIN_WINDOW_MS
      });
      authError = "Invalid password.";
    }
    }
  }

  if (intent === "update-status" && (hasValidSession || isAuthed)) {
    const leadId = String(formData.get("leadId") ?? "").trim();
    const nextStatus = String(formData.get("status") ?? "").trim();
    if (!leadId || !(LEAD_STATUSES as readonly string[]).includes(nextStatus)) {
      actionMessage = "Status update failed.";
    } else {
      const updated = await updateLeadStatus(leadId, nextStatus as LeadStatus);
      actionMessage = updated ? "Lead status updated." : "Lead not found.";
    }
  }

  if (intent === "add-note" && (hasValidSession || isAuthed)) {
    const leadId = String(formData.get("leadId") ?? "").trim();
    const noteText = String(formData.get("note") ?? "").trim();
    if (!leadId || !noteText) {
      actionMessage = "Note cannot be empty.";
    } else {
      const updated = await addLeadNote(leadId, noteText);
      actionMessage = updated ? "Note added." : "Lead not found.";
    }
  }
}

const leads = isAuthed ? (await readLeads()).sort((a, b) => b.timestamp.localeCompare(a.timestamp)) : [];
const statusesToShow = selectedStatusFilter === "all" ? [...LEAD_STATUSES] : [selectedStatusFilter];
---

<BaseLayout title="NexoraAI Admin | Leads" description="Internal lead dashboard for NexoraAI.">
  <main class="section-spacing">
    <div class="container-shell">
      <div class="mx-auto max-w-6xl">
        <h1 class="text-3xl font-semibold tracking-tight text-white md:text-4xl">Lead Dashboard</h1>
        <p class="mt-3 text-sm text-text-muted">Internal dashboard for incoming NexoraAI leads.</p>
        {usingDevPasswordFallback && <p class="mt-2 text-xs text-amber-300">Using dev fallback password. Set `ADMIN_PASSWORD` for production.</p>}
        {actionMessage && <p class="mt-3 text-sm text-emerald-300">{actionMessage}</p>}

        {
          !isAuthed ? (
            <div class="card-surface mt-10 max-w-xl p-7">
              <h2 class="text-xl font-semibold text-white">Admin Access</h2>
              <p class="mt-2 text-sm text-text-muted">Enter your admin password to view lead submissions.</p>

              <form method="POST" class="mt-6 grid gap-4">
                <input type="hidden" name="intent" value="login" />
                <label class="grid gap-2">
                  <span class="text-sm font-medium text-white">Password</span>
                  <input
                    required
                    type="password"
                    name="password"
                    class="rounded-xl border border-border-subtle bg-surface px-4 py-3 text-sm text-white outline-none transition focus:border-brand-strong"
                    placeholder="Enter ADMIN_PASSWORD"
                  />
                </label>
                {authError && <p class="text-sm text-rose-300">{authError}</p>}
                <button type="submit" class="btn-primary w-fit">Unlock dashboard</button>
              </form>
            </div>
          ) : (
            <div class="mt-8">
              <form method="GET" class="card-surface flex flex-wrap items-center gap-3 p-4">
                <label for="status-filter" class="text-sm text-text-muted">Filter status</label>
                <select
                  id="status-filter"
                  name="status"
                  class="rounded-lg border border-border-subtle bg-surface px-3 py-2 text-sm text-white outline-none"
                >
                  <option value="all" selected={selectedStatusFilter === "all"}>All statuses</option>
                  {
                    LEAD_STATUSES.map((status) => (
                      <option value={status} selected={selectedStatusFilter === status}>
                        {statusLabels[status]}
                      </option>
                    ))
                  }
                </select>
                <button type="submit" class="btn-secondary !px-4 !py-2">Apply</button>
              </form>
            </div>
          )
        }

        {
          isAuthed &&
            (leads.length === 0 ? (
              <div class="card-surface mt-6 p-8 text-center text-text-muted">No leads submitted yet.</div>
            ) : (
              statusesToShow.map((status) => {
                const statusLeads = leads.filter((lead) => lead.status === status);
                return (
                  <section class="card-surface mt-6 p-0">
                    <div class="flex items-center justify-between border-b border-border-subtle bg-surface px-5 py-4">
                      <h2 class="text-base font-semibold text-white">{statusLabels[status]}</h2>
                      <span class={`rounded-full border px-2.5 py-1 text-xs font-medium ${statusBadgeClass[status]}`}>
                        {statusLeads.length} lead{statusLeads.length === 1 ? "" : "s"}
                      </span>
                    </div>

                    {statusLeads.length === 0 ? (
                      <div class="px-5 py-8 text-center text-sm text-text-muted">No leads in this stage.</div>
                    ) : (
                      <div class="grid gap-4 p-4 md:grid-cols-2">
                        {statusLeads.map((lead) => (
                          <article class="card-surface p-5">
                            <div class="flex flex-wrap items-start justify-between gap-3">
                              <div>
                                <h3 class="text-base font-semibold text-white">{lead.name}</h3>
                                <p class="mt-0.5 text-sm text-text-muted">{lead.company}</p>
                              </div>
                              <span class={`rounded-full border px-2.5 py-1 text-xs font-medium ${statusBadgeClass[lead.status]}`}>
                                {statusLabels[lead.status]}
                              </span>
                            </div>

                            <p class="mt-3 text-sm text-text-muted">{lead.email}</p>
                            <p class="mt-2 text-sm leading-relaxed text-text-muted">
                              {lead.message.length > 180 ? `${lead.message.slice(0, 180)}...` : lead.message}
                            </p>
                            <p class="mt-2 text-xs text-text-muted">{new Date(lead.timestamp).toLocaleString()}</p>

                            <div class="mt-4 rounded-lg border border-border-subtle bg-surface/40 p-3">
                              <p class="text-[11px] font-medium uppercase tracking-wide text-text-muted">Next action</p>
                              <p class="mt-1 text-xs text-white">{getSuggestedNextAction(lead.status)}</p>
                            </div>

                            <div class="mt-3 rounded-lg border border-border-subtle bg-surface/40 p-3">
                              <p class="text-[11px] font-medium uppercase tracking-wide text-text-muted">Pipeline actions</p>
                              <form method="POST" class="mt-2 flex items-center gap-2">
                                <input type="hidden" name="intent" value="update-status" />
                                <input type="hidden" name="leadId" value={lead.id} />
                                <select
                                  name="status"
                                  class="rounded-lg border border-border-subtle bg-surface px-3 py-2 text-xs text-white outline-none transition focus:border-brand-strong"
                                >
                                  {
                                    LEAD_STATUSES.map((nextStatus) => (
                                      <option value={nextStatus} selected={lead.status === nextStatus}>
                                        {statusLabels[nextStatus]}
                                      </option>
                                    ))
                                  }
                                </select>
                                <button type="submit" class="btn-secondary !px-3 !py-2 text-xs">Update</button>
                              </form>
                              <p class="mt-2 text-xs text-text-muted">{getSuggestedOutreachMessage(lead.status, lead)}</p>
                            </div>

                            <div class="mt-3 rounded-lg border border-border-subtle bg-surface/40 p-3">
                              <p class="text-[11px] font-medium uppercase tracking-wide text-text-muted">Internal notes</p>
                              <div class="mt-2 space-y-2">
                                {lead.notes.length === 0 ? (
                                  <p class="text-xs text-text-muted">No notes yet.</p>
                                ) : (
                                  lead.notes
                                    .slice()
                                    .reverse()
                                    .slice(0, 3)
                                    .map((note) => (
                                      <div class="rounded border border-border-subtle/70 px-2 py-1.5">
                                        <p class="text-xs text-white">{note.text}</p>
                                        <p class="mt-1 text-[11px] text-text-muted">{new Date(note.createdAt).toLocaleString()}</p>
                                      </div>
                                    ))
                                )}
                              </div>
                              <form method="POST" class="mt-3 flex items-center gap-2">
                                <input type="hidden" name="intent" value="add-note" />
                                <input type="hidden" name="leadId" value={lead.id} />
                                <input
                                  type="text"
                                  name="note"
                                  placeholder="Add internal note"
                                  class="w-full rounded-lg border border-border-subtle bg-surface px-3 py-2 text-xs text-white outline-none transition focus:border-brand-strong"
                                />
                                <button type="submit" class="btn-secondary !px-3 !py-2 text-xs">Add</button>
                              </form>
                            </div>
                          </article>
                        ))}
                      </div>
                    )}
                  </section>
                );
              })
            ))
        }
      </div>
    </div>
  </main>
</BaseLayout>
