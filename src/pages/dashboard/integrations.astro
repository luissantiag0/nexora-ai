---
import DashboardLayout from "../../layouts/DashboardLayout.astro";

export const prerender = false;

const integrations = [
  {
    id: "whatsapp",
    name: "WhatsApp API",
    desc: "Conecta AverionAI con WhatsApp para automatizar conversaciones y notificaciones.",
    connected: false,
    fields: [
      { label: "Numero de telefono", placeholder: "+34 600 000 000" },
      { label: "Token de API", placeholder: "EAAT..." },
      { label: "ID de negocio", placeholder: "123456789" },
    ],
  },
  {
    id: "gmail",
    name: "Gmail API",
    desc: "Conecta AverionAI con Gmail para enviar y recibir correos automaticamente.",
    connected: false,
    oauth: true,
  },
  {
    id: "webhooks",
    name: "Webhooks",
    desc: "Recibe notificaciones en tiempo real cuando ocurren eventos en AverionAI.",
    connected: false,
    events: ["lead.created", "lead.updated", "lead.moved", "document.generated"],
  },
];
---

<DashboardLayout title="Integraciones">
  <section class="rounded-2xl border border-white/[0.06] bg-white/[0.02] p-6 md:p-8">
    <p class="text-xs uppercase tracking-[0.18em] text-cyan-100/70">Conexiones</p>
    <h2 class="mt-3 text-3xl font-semibold tracking-tight text-white md:text-4xl">Integraciones</h2>
    <p class="mt-3 max-w-2xl text-sm leading-relaxed text-white/55">Conecta AverionAI con las herramientas que tu equipo ya utiliza.</p>
  </section>

  <section class="mt-8 grid gap-6">
    {integrations.map((int, i) => (
      <div class="premium-panel p-5 md:p-6" data-reveal data-delay={i * 80}>
        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
          <div class="flex items-start gap-4">
            <span class={`flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border ${int.connected ? "border-emerald-300/20 bg-emerald-300/[0.08]" : "border-white/[0.08] bg-white/[0.03]"}`}>
              {int.id === "whatsapp" && <svg class="h-6 w-6 text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>}
              {int.id === "gmail" && <svg class="h-6 w-6 text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>}
              {int.id === "webhooks" && <svg class="h-6 w-6 text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>}
            </span>
            <div>
              <h3 class="text-lg font-semibold text-white">{int.name}</h3>
              <p class="mt-1 text-sm text-white/50">{int.desc}</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <span class={`text-xs font-medium px-3 py-1 rounded-full border ${int.connected ? "border-emerald-300/20 bg-emerald-300/[0.06] text-emerald-200" : "border-white/[0.08] bg-white/[0.03] text-white/40"}`}>{int.connected ? "Conectado" : "No conectado"}</span>
            <button class="btn-secondary px-4 py-2 text-xs config-btn" data-integration={int.id}>Configurar</button>
          </div>
        </div>
      </div>
    ))}
  </section>

  <div id="whatsapp-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm">
    <div class="mx-4 w-full max-w-md rounded-2xl border border-white/[0.08] bg-[#07070A] p-6 shadow-[0_40px_100px_-40px_rgba(34,211,238,0.3)] md:p-8">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-xl font-semibold text-white">WhatsApp API</h3>
        <button class="close-modal text-white/30 hover:text-white/60 transition"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>
      </div>
      <div class="space-y-4">
        {[{l: "Numero de telefono", p: "+34 600 000 000"},{l: "Token de API", p: "EAAT..."},{l: "ID de negocio", p: "123456789"}].map((f) => (
          <label class="block space-y-1.5"><span class="text-sm text-white/60">{f.l}</span><input class="input-premium w-full" placeholder={f.p} /></label>
        ))}
        <button class="w-full rounded-xl bg-white px-6 py-3 text-sm font-semibold text-black transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_16px_40px_-20px_rgba(34,211,238,0.6)]">Guardar configuracion</button>
      </div>
    </div>
  </div>

  <div id="gmail-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm">
    <div class="mx-4 w-full max-w-md rounded-2xl border border-white/[0.08] bg-[#07070A] p-6 shadow-[0_40px_100px_-40px_rgba(34,211,238,0.3)] md:p-8">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-xl font-semibold text-white">Gmail API</h3>
        <button class="close-modal text-white/30 hover:text-white/60 transition"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>
      </div>
      <p class="text-sm text-white/50">Conecta AverionAI con Gmail mediante OAuth 2.0. Una vez conectado, podras enviar y recibir correos directamente desde el CRM.</p>
      <button class="mt-6 w-full rounded-xl border border-cyan-300/20 bg-cyan-300/[0.06] px-6 py-3 text-sm font-semibold text-cyan-200 transition-all duration-300 hover:-translate-y-0.5">Conectar Gmail</button>
    </div>
  </div>

  <div id="webhooks-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm">
    <div class="mx-4 w-full max-w-md rounded-2xl border border-white/[0.08] bg-[#07070A] p-6 shadow-[0_40px_100px_-40px_rgba(34,211,238,0.3)] md:p-8">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-xl font-semibold text-white">Webhooks</h3>
        <button class="close-modal text-white/30 hover:text-white/60 transition"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>
      </div>
      <div class="space-y-4">
        <label class="block space-y-1.5"><span class="text-sm text-white/60">URL</span><input class="input-premium w-full" placeholder="https://tuapp.com/webhook" /></label>
        <label class="block space-y-1.5"><span class="text-sm text-white/60">Evento</span><select class="input-premium w-full">{["lead.created","lead.updated","lead.moved","document.generated"].map((e) => <option>{e}</option>)}</select></label>
        <button class="w-full rounded-xl bg-white px-6 py-3 text-sm font-semibold text-black transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_16px_40px_-20px_rgba(34,211,238,0.6)]">Crear webhook</button>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  (() => {
    const integrations = ["whatsapp", "gmail", "webhooks"];

    document.querySelectorAll(".config-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.dataset.integration;
        const modal = document.getElementById(`${id}-modal`);
        if (modal) modal.classList.remove("hidden", "flex") || modal.classList.add("flex");
      });
    });

    document.querySelectorAll(".close-modal").forEach((btn) => {
      btn.addEventListener("click", () => {
        btn.closest("[id$=-modal]")?.classList.add("hidden");
      });
    });
  })();
</script>
