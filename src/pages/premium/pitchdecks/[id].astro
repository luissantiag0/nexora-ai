---
import PremiumLayout from "../../../layouts/PremiumLayout.astro";
import { getUserPitchDeck, type PitchSection } from "../../../lib/pitchDeck";

export const prerender = false;

const user = Astro.locals.user;
const deckId = Astro.params.id!;
const deck = user ? await getUserPitchDeck(deckId, user.id) : null;
if (!deck) return Astro.redirect("/premium/pitchdecks");

const sections: PitchSection[] = deck.sections ? JSON.parse(deck.sections) : [];
---

<PremiumLayout title={deck.title}>
  <a href="/premium/pitchdecks" class="text-sm text-white/45 transition hover:text-cyan-100">← Volver</a>

  <section class="mt-5 rounded-2xl border border-white/10 bg-white/[0.035] p-6 md:p-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-xs uppercase tracking-[0.18em] text-cyan-100/70">Pitch deck</p>
        <h2 class="mt-2 text-3xl font-semibold tracking-tight text-white md:text-4xl">{deck.title}</h2>
        {deck.clientType && <p class="mt-2 text-sm text-white/55">{deck.clientType}{deck.objective ? ` · ${deck.objective}` : ""}</p>}
      </div>
      <div class="flex flex-wrap gap-3">
        <a href={`/api/pitchdecks/${deck.id}?download=1`} target="_blank" class="btn-primary px-5 py-2.5 text-sm">Exportar PDF</a>
        <button type="button" id="save-deck" class="btn-secondary px-5 py-2.5 text-sm">Guardar</button>
      </div>
    </div>
  </section>

  <section class="mt-8 grid gap-6">
    {sections.map((section, index) => (
      <div class="premium-panel p-5 md:p-6">
        <div class="flex items-center justify-between">
          <h3 class="text-lg font-semibold text-white">
            <span class="text-cyan-100/60">0{index + 1}.</span> {section.title}
          </h3>
          <span class="text-xs text-white/35" data-word-count={index}>0 palabras</span>
        </div>
        <textarea
          data-section={index}
          rows="5"
          class="input-premium mt-4 w-full resize-y"
          placeholder="Escribe el contenido de esta sección..."
        >{section.content}</textarea>
      </div>
    ))}
  </section>
</PremiumLayout>

<script>
  (() => {
    const deckId = window.location.pathname.split("/").pop();
    const textareas = document.querySelectorAll("textarea[data-section]");

    textareas.forEach((ta) => {
      const updateCount = () => {
        const words = (ta as HTMLTextAreaElement).value.trim().split(/\s+/).filter(Boolean).length;
        const el = document.querySelector(`[data-word-count="${ta.dataset.section}"]`);
        if (el) el.textContent = `${words} palabras`;
      };
      ta.addEventListener("input", updateCount);
      updateCount();
    });

    document.getElementById("save-deck")?.addEventListener("click", async () => {
      const sections = Array.from(textareas).map((ta, i) => ({
        title: document.querySelectorAll(".premium-panel h3")[i]?.textContent?.replace(/^\d+\.\s*/, "").trim() || "",
        content: (ta as HTMLTextAreaElement).value,
      }));

      const res = await fetch(`/api/pitchdecks/${deckId}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ sections }),
      });

      if (res.ok) {
        const btn = document.getElementById("save-deck");
        if (btn) { btn.textContent = "Guardado ✓"; setTimeout(() => { btn.textContent = "Guardar"; }, 2000); }
      }
    });
  })();
</script>
