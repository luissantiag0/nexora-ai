---
import PremiumLayout from "../../layouts/PremiumLayout.astro";
import { getUserPitchDecks } from "../../lib/pitchDeck";

export const prerender = false;

const user = Astro.locals.user;
const decks = user ? await getUserPitchDecks(user.id) : [];
const hasDecks = decks.length > 0;
---

<PremiumLayout title="Pitch decks">
  <section class="rounded-2xl border border-white/10 bg-white/[0.035] p-6 md:p-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-xs uppercase tracking-[0.18em] text-cyan-100/70">Sales enablement</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-white md:text-4xl">Pitch decks</h2>
        <p class="mt-3 max-w-3xl text-sm leading-relaxed text-white/55">Crea presentaciones comerciales con IA o edítalas manualmente. Exporta a PDF.</p>
      </div>
    </div>
  </section>

  <section class="mt-8 grid gap-6 xl:grid-cols-[1fr_1fr]">
    <div class="premium-panel p-5 md:p-6">
      <h2 class="text-xl font-semibold text-white">Nuevo pitch deck</h2>
      <form id="deck-form" class="mt-5 grid gap-4">
        <label class="block space-y-1.5"><span class="text-sm text-white/65">Título *</span><input id="deck-title" type="text" required class="input-premium w-full" placeholder="Ej: Automatización para Retail" /></label>
        <label class="block space-y-1.5"><span class="text-sm text-white/65">Tipo de cliente</span><input id="deck-client" type="text" class="input-premium w-full" placeholder="Ej: Pyme, Corporación, Startup" /></label>
        <label class="block space-y-1.5"><span class="text-sm text-white/65">Objetivo comercial</span><textarea id="deck-objective" rows="3" class="input-premium w-full resize-none" placeholder="Ej: Vender automatización de procesos comerciales"></textarea></label>
        <div class="flex flex-wrap gap-3">
          <button type="button" id="deck-generate-ai" class="btn-primary px-5 py-3 text-sm">Generar con IA</button>
          <button type="button" id="deck-create-manual" class="btn-secondary px-5 py-3 text-sm">Crear vacío</button>
        </div>
      </form>
    </div>

    <div class="premium-panel p-5 md:p-6">
      <h2 class="text-xl font-semibold text-white">Mis pitch decks</h2>
      {!hasDecks ? (
        <div class="mt-5 rounded-2xl border border-dashed border-white/10 bg-black/15 p-5 text-sm text-white/45">Aún no tienes pitch decks. Crea uno nuevo.</div>
      ) : (
        <div class="mt-5 grid gap-3">
          {decks.map((deck) => {
            const sections = deck.sections ? JSON.parse(deck.sections) : [];
            const completed = sections.filter((s: any) => s.content).length;
            return (
              <a href={`/premium/pitchdecks/${deck.id}`} class="rounded-2xl border border-white/10 bg-black/20 p-4 transition hover:border-cyan-300/30">
                <div class="flex items-center justify-between">
                  <div>
                    <p class="font-medium text-white">{deck.title}</p>
                    <p class="mt-1 text-xs text-white/45">{deck.clientType || "Sin tipo"} · {completed}/{sections.length} secciones</p>
                  </div>
                  <span class="rounded-full border border-white/10 bg-white/[0.04] px-2.5 py-0.5 text-[11px] text-white/50">{deck.status}</span>
                </div>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </section>
</PremiumLayout>

<script>
  (() => {
    document.getElementById("deck-generate-ai")?.addEventListener("click", async () => {
      const btn = document.getElementById("deck-generate-ai");
      if (!btn) return;
      btn.textContent = "Generando..."; btn.disabled = true;
      try {
        const res = await fetch("/api/pitchdecks", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            title: (document.getElementById("deck-title") as HTMLInputElement)?.value || "Pitch Deck",
            clientType: (document.getElementById("deck-client") as HTMLInputElement)?.value || "",
            objective: (document.getElementById("deck-objective") as HTMLTextAreaElement)?.value || "",
            useAI: true,
          }),
        });
        const data = await res.json();
        if (data.deck?.id) window.location.href = `/premium/pitchdecks/${data.deck.id}`;
      } catch { alert("Error al generar"); }
      finally { btn.textContent = "Generar con IA"; btn.disabled = false; }
    });

    document.getElementById("deck-create-manual")?.addEventListener("click", async () => {
      const btn = document.getElementById("deck-create-manual");
      if (!btn) return;
      btn.textContent = "Creando..."; btn.disabled = true;
      try {
        const res = await fetch("/api/pitchdecks", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            title: (document.getElementById("deck-title") as HTMLInputElement)?.value || "Pitch Deck",
            clientType: (document.getElementById("deck-client") as HTMLInputElement)?.value || "",
            objective: (document.getElementById("deck-objective") as HTMLTextAreaElement)?.value || "",
            useAI: false,
          }),
        });
        const data = await res.json();
        if (data.deck?.id) window.location.href = `/premium/pitchdecks/${data.deck.id}`;
      } catch { alert("Error al crear"); }
      finally { btn.textContent = "Crear vacío"; btn.disabled = false; }
    });
  })();
</script>
