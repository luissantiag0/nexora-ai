---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { SESSION_COOKIE } from "../lib/session";
import { getCurrentUser } from "../lib/auth";

export const prerender = false;

const token = Astro.cookies.get(SESSION_COOKIE)?.value;
const user = await getCurrentUser(token);
const isLoggedIn = !!user;
---

<BaseLayout title="Invita y gana | AverionAI" description="Invita a otras empresas a usar AverionAI y obtén descuentos exclusivos.">
  <Navbar />
  <main class="min-h-screen bg-[#07070A]">
    <section class="container py-20 md:py-28">
      <div class="mx-auto max-w-3xl text-center" data-reveal>
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl border border-emerald-300/20 bg-emerald-300/10">
          <span class="text-2xl icon-pulse-soft">🎯</span>
        </div>
        <h1 class="mt-6 text-4xl font-semibold tracking-tight text-white md:text-5xl">Programa de referidos</h1>
        <p class="mx-auto mt-4 max-w-lg text-base text-white/60">Invita a otras empresas a automatizar con AverionAI y ambos recibís beneficios exclusivos.</p>
      </div>

      <div class="mx-auto mt-16 grid max-w-4xl gap-6 md:grid-cols-3">
        <div class="card-premium-hover p-6 text-center" data-reveal data-delay="0">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-xl bg-cyan-300/10 text-2xl icon-float">1</div>
          <h3 class="mt-4 text-lg font-semibold text-white">Comparte tu enlace</h3>
          <p class="mt-3 text-sm text-white/60">Envía tu código de invitación a otras empresas que puedan beneficiarse de AverionAI.</p>
        </div>
        <div class="card-premium-hover p-6 text-center" data-reveal data-delay="100">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-xl bg-emerald-300/10 text-2xl icon-float" style="animation-delay: 0.5s">2</div>
          <h3 class="mt-4 text-lg font-semibold text-white">Se registran</h3>
          <p class="mt-3 text-sm text-white/60">La empresa invitada se registra y activa su prueba gratuita usando tu código.</p>
        </div>
        <div class="card-premium-hover p-6 text-center" data-reveal data-delay="200">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-xl bg-purple-300/10 text-2xl icon-float" style="animation-delay: 1s">3</div>
          <h3 class="mt-4 text-lg font-semibold text-white">Ganáis ambos</h3>
          <p class="mt-3 text-sm text-white/60">Tú y la empresa invitada recibís un 20% de descuento en vuestra suscripción premium.</p>
        </div>
      </div>

      <div class="mx-auto mt-12 max-w-lg text-center">
        {isLoggedIn ? (
          <div class="rounded-2xl border border-cyan-300/20 bg-cyan-300/5 p-6" data-reveal>
            <p class="text-sm text-cyan-200">Tu código de invitación</p>
            <p class="mt-2 text-3xl font-bold tracking-widest text-white">{user?.id?.slice(0, 8).toUpperCase()}</p>
            <button type="button" onclick="navigator.clipboard.writeText(window.location.origin + '/register?ref=' + '{$user?.id?.slice(0, 8)}')" class="btn-secondary mt-4 px-5 py-2.5 text-sm">
              Copiar enlace
            </button>
          </div>
        ) : (
          <a href="/register" class="btn-primary px-8 py-3 text-sm">
            Crear cuenta y participar
          </a>
        )}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
