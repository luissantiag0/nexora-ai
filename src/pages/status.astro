---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

export const prerender = false;

const services = [
  { name: "API Principal", status: "ok", uptime: "99.9%" },
  { name: "Base de datos", status: "ok", uptime: "99.9%" },
  { name: "Autenticación", status: "ok", uptime: "99.9%" },
  { name: "IA (Mock)", status: "ok", uptime: "100%" },
  { name: "PDF Generator", status: "ok", uptime: "99.8%" },
  { name: "Stripe", status: "ok", uptime: "99.9%" },
  { name: "Email (Resend)", status: "ok", uptime: "99.9%" },
  { name: "CDN / Assets", status: "ok", uptime: "100%" },
];
---

<BaseLayout title="Estado del sistema | AverionAI" description="Estado en tiempo real de los servicios de AverionAI.">
  <Navbar />
  <main class="min-h-screen bg-[#07070A]">
    <section class="container py-20 md:py-28">
      <div class="mx-auto max-w-3xl text-center" data-reveal>
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl border border-emerald-300/20 bg-emerald-300/10">
          <span class="text-2xl icon-pulse-soft">🟢</span>
        </div>
        <h1 class="mt-5 text-4xl font-semibold text-white md:text-5xl">Todos los sistemas operativos</h1>
        <p class="mt-4 text-white/60">Estado en tiempo real de los servicios de AverionAI.</p>
      </div>

      <div class="mx-auto mt-16 grid max-w-3xl gap-4">
        {services.map((svc, i) => (
          <div class="flex items-center justify-between rounded-xl border border-white/10 bg-white/[0.03] px-6 py-4" data-reveal data-delay={i * 50}>
            <div class="flex items-center gap-4">
              <span class={`h-3 w-3 rounded-full ${svc.status === "ok" ? "bg-emerald-400 shadow-[0_0_12px_rgba(52,211,153,0.5)]" : "bg-red-400"}`}></span>
              <span class="text-sm font-medium text-white">{svc.name}</span>
            </div>
            <div class="flex items-center gap-4">
              <span class="text-xs text-white/40">{svc.uptime} uptime</span>
              <span class="text-xs font-medium text-emerald-400 bg-emerald-400/10 px-2 py-0.5 rounded-full">Operativo</span>
            </div>
          </div>
        ))}
      </div>

      <div class="mx-auto mt-10 max-w-3xl rounded-xl border border-white/10 bg-white/[0.02] px-6 py-5 text-center">
        <p class="text-sm text-white/50">Última actualización: {new Date().toISOString().replace("T", " ").substring(0, 19)} UTC</p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
