---
import BusinessLayout from "../../layouts/BusinessLayout.astro";
export const prerender = false;

const roles = ["Admin", "Editor", "Viewer", "Manager", "Supervisor", "Analista", "Integrador"];
const modules = ["CRM", "Documentos", "Automatizaciones", "Integraciones", "Configuracion"];
const advPerms = ["Auto. avanzadas", "Integraciones criticas", "Auditoria global", "API Keys", "Config. Business"];
---

<BusinessLayout title="Roles">
  <section class="rounded-2xl border border-white/[0.06] bg-white/[0.02] p-6 md:p-8">
    <p class="text-xs uppercase tracking-wider text-cyan-100/70">Permisos</p>
    <h2 class="mt-3 text-3xl font-semibold tracking-tight text-white md:text-4xl">Roles avanzados</h2>
    <p class="mt-3 text-sm text-white/50">Controla lo que cada usuario puede hacer en AverionAI.</p>
  </section>

  <section class="mt-6 premium-panel overflow-hidden">
    <div class="overflow-x-auto">
      <table class="table-premium">
        <thead><tr><th>Rol</th>{modules.map((m) => <th class="text-center">{m}</th>)}<th class="text-right">Accion</th></tr></thead>
        <tbody>
          {[{n:"Admin",p:["full","full","full","full","full"]},{n:"Manager",p:["full","full","full","edicion","edicion"]},{n:"Editor",p:["full","full","edicion","lectura","lectura"]},{n:"Supervisor",p:["full","lectura","lectura","lectura","lectura"]},{n:"Analista",p:["lectura","lectura","lectura","sin","sin"]},{n:"Integrador",p:["lectura","lectura","full","full","lectura"]},{n:"Viewer",p:["lectura","lectura","sin","sin","sin"]}].map((r) => (
            <tr><td class="font-medium text-white">{r.n}</td>{r.p.map((v) => <td class="text-center"><span class={`inline-block h-2 w-2 rounded-full ${v === "full" ? "bg-emerald-400" : v === "edicion" ? "bg-amber-400" : v === "lectura" ? "bg-cyan-400" : "bg-white/20"}`}></span></td>)}<td class="text-right"><button class="text-xs text-cyan-200 hover:text-white transition">Editar</button></td></tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-6 premium-panel p-5 md:p-6">
    <h2 class="text-lg font-semibold text-white">Permisos avanzados</h2>
    <div class="mt-5 grid gap-3">
      {advPerms.map((p) => (
        <div class="flex items-center justify-between rounded-xl border border-white/[0.06] bg-white/[0.02] px-5 py-3">
          <span class="text-sm text-white/70">{p}</span>
          <div class="flex gap-4 text-xs text-white/40">
            <span>Admin: <span class="text-emerald-300">Full</span></span>
            <span>Manager: <span class="text-emerald-300">Full</span></span>
            <span>Editor: <span class="text-amber-300">Edicion</span></span>
            <span>Viewer: <span class="text-cyan-300">Lectura</span></span>
          </div>
        </div>
      ))}
    </div>
  </section>
</BusinessLayout>
