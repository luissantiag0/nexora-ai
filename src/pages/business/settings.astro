---
import BusinessLayout from "../../layouts/BusinessLayout.astro";
export const prerender = false;

const languages = ["Español", "English", "Português", "Français"];
const timezones = ["Europe/Madrid", "Europe/London", "America/New_York", "America/Mexico_City", "America/Sao_Paulo"];
const dateFormats = ["DD/MM/YYYY", "MM/DD/YYYY", "YYYY-MM-DD"];
const currencies = ["EUR", "USD", "BRL", "GBP"];
---

<BusinessLayout title="Settings">
  <section class="rounded-2xl border border-white/[0.06] bg-white/[0.02] p-6 md:p-8">
    <p class="text-xs uppercase tracking-wider text-cyan-100/70">Configuracion</p>
    <h2 class="mt-3 text-3xl font-semibold tracking-tight text-white md:text-4xl">Ajustes Business</h2>
    <p class="mt-3 text-sm text-white/50">Configura la informacion de tu empresa y preferencias del sistema.</p>
  </section>

  <section class="mt-8 grid gap-6 xl:grid-cols-2">
    <div class="premium-panel p-5 md:p-6">
      <h2 class="text-lg font-semibold text-white">Informacion de la empresa</h2>
      <div class="mt-5 grid gap-4">
        <label class="block space-y-1.5"><span class="text-sm text-white/60">Nombre</span><input class="input-premium w-full" value="Mi Empresa" /></label>
        <label class="block space-y-1.5"><span class="text-sm text-white/60">Sector</span><select class="input-premium w-full"><option selected>Tecnologia</option><option>Consultoria</option><option>Ecommerce</option><option>Salud</option></select></label>
        <label class="block space-y-1.5"><span class="text-sm text-white/60">Direccion</span><input class="input-premium w-full" placeholder="Calle, ciudad, pais" /></label>
        <label class="block space-y-1.5"><span class="text-sm text-white/60">Telefono</span><input class="input-premium w-full" placeholder="+34 600 000 000" /></label>
        <label class="block space-y-1.5"><span class="text-sm text-white/60">Logo</span><div class="flex items-center gap-4"><div class="flex h-16 w-16 items-center justify-center rounded-xl border border-white/[0.08] bg-white/[0.03] text-sm text-white/30">Logo</div><button class="btn-secondary px-4 py-2 text-xs">Subir imagen</button></div></label>
        <button class="btn-primary w-fit px-6 py-2.5 text-sm mt-2">Guardar cambios</button>
      </div>
    </div>

    <div class="grid gap-6">
      <div class="premium-panel p-5 md:p-6">
        <h2 class="text-lg font-semibold text-white">Preferencias del sistema</h2>
        <div class="mt-5 grid gap-4">
          <label class="block space-y-1.5"><span class="text-sm text-white/60">Idioma</span><select class="input-premium w-full">{languages.map((l) => <option selected={l === "Español"}>{l}</option>)}</select></label>
          <label class="block space-y-1.5"><span class="text-sm text-white/60">Zona horaria</span><select class="input-premium w-full">{timezones.map((t) => <option selected={t === "Europe/Madrid"}>{t}</option>)}</select></label>
          <label class="block space-y-1.5"><span class="text-sm text-white/60">Formato de fecha</span><select class="input-premium w-full">{dateFormats.map((d) => <option selected={d === "DD/MM/YYYY"}>{d}</option>)}</select></label>
          <label class="block space-y-1.5"><span class="text-sm text-white/60">Moneda</span><select class="input-premium w-full">{currencies.map((c) => <option selected={c === "EUR"}>{c}</option>)}</select></label>
        </div>
      </div>

      <div class="premium-panel p-5 md:p-6">
        <h2 class="text-lg font-semibold text-white">Notificaciones</h2>
        <div class="mt-5 grid gap-4">
          {[{l:"Notificaciones por email",d:"Recibir alertas por correo"},{l:"Notificaciones por WhatsApp",d:"Recibir alertas por WhatsApp"},{l:"Notificaciones internas",d:"Notificaciones en el dashboard"}].map((n) => (
            <label class="flex items-center justify-between rounded-xl border border-white/[0.06] bg-white/[0.02] px-4 py-3 cursor-pointer"><div><p class="text-sm text-white/80">{n.l}</p><p class="text-xs text-white/40">{n.d}</p></div><input type="checkbox" class="accent-cyan-300 h-5 w-5" checked /></label>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="mt-6 premium-panel p-5 md:p-6">
    <h2 class="text-lg font-semibold text-white">Privacidad</h2>
    <div class="mt-5 grid gap-4">
      {[{l:"Visibilidad de usuarios",d:"Los usuarios pueden ver perfiles de otros miembros del equipo"},{l:"Permisos de datos",d:"Restringir exportacion de datos a roles especificos"}].map((p) => (
        <label class="flex items-center justify-between rounded-xl border border-white/[0.06] bg-white/[0.02] px-4 py-3 cursor-pointer"><div><p class="text-sm text-white/80">{p.l}</p><p class="text-xs text-white/40">{p.d}</p></div><input type="checkbox" class="accent-cyan-300 h-5 w-5" checked /></label>
      ))}
    </div>
  </section>
</BusinessLayout>
