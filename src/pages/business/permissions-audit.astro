---
import BusinessLayout from "../../layouts/BusinessLayout.astro";
export const prerender = false;

const users = [
  { name: "Ana Garcia", email: "ana@empresa.com", role: "Admin", perms: "Full", lastMod: "Hoy" },
  { name: "Carlos Lopez", email: "carlos@empresa.com", role: "Editor", perms: "CRM, Docs", lastMod: "Ayer" },
  { name: "Maria Perez", email: "maria@empresa.com", role: "Viewer", perms: "Lectura", lastMod: "Hace 3 dias" },
  { name: "Pedro Sanchez", email: "pedro@empresa.com", role: "Manager", perms: "CRM, Docs, Auto.", lastMod: "Hace 1 sem" },
];

const changes = [
  { who: "Admin", what: "Permiso de Carlos Lopez", from: "Editor -> Manager", when: "Hace 1 h", type: "upgrade" },
  { who: "Admin", what: "Acceso a API Keys", to: "Integrador", when: "Hace 3 h", type: "add" },
  { who: "Sistema", what: "Nuevo usuario: Pedro Sanchez", role: "Manager", when: "Hace 1 d", type: "add" },
  { who: "Admin", what: "Permiso de Maria Perez", from: "Viewer -> Editor", when: "Hace 2 d", type: "upgrade" },
  { who: "Sistema", what: "Rol eliminado: Invitado", from: "", when: "Hace 5 d", type: "remove" },
];
---

<BusinessLayout title="Auditoria">
  <section class="rounded-2xl border border-white/[0.06] bg-white/[0.02] p-6 md:p-8">
    <p class="text-xs uppercase tracking-wider text-cyan-100/70">Auditoria</p>
    <h2 class="mt-3 text-3xl font-semibold tracking-tight text-white md:text-4xl">Auditoria de permisos</h2>
    <p class="mt-3 text-sm text-white/50">Historial de cambios y permisos activos por usuario.</p>
  </section>

  <section class="mt-6 grid gap-6 xl:grid-cols-[1.2fr_0.8fr]">
    <div class="premium-panel p-5 md:p-6">
      <h2 class="text-lg font-semibold text-white">Usuarios y permisos</h2>
      <div class="mt-5 grid gap-3">
        {users.map((u, i) => (
          <div class="flex items-center justify-between rounded-xl border border-white/[0.06] bg-white/[0.02] px-4 py-3.5 transition-all duration-200 hover:bg-white/[0.03]" data-reveal data-delay={i * 50}>
            <div class="flex items-center gap-4">
              <span class="flex h-9 w-9 items-center justify-center rounded-lg border border-white/[0.08] bg-white/[0.03] text-xs font-bold text-cyan-200">{u.name[0]}</span>
              <div><p class="text-sm font-medium text-white">{u.name}</p><p class="text-xs text-white/40">{u.email}</p></div>
            </div>
            <div class="text-right"><span class="rounded-full border border-cyan-300/20 bg-cyan-300/10 px-2.5 py-0.5 text-[11px] text-cyan-200">{u.role}</span><p class="text-[11px] text-white/30 mt-1">{u.perms} · {u.lastMod}</p></div>
          </div>
        ))}
      </div>
    </div>

    <div class="premium-panel p-5 md:p-6">
      <h2 class="text-lg font-semibold text-white">Historial de cambios</h2>
      <div class="mt-5 grid gap-3">
        {changes.map((c, i) => (
          <div class="rounded-xl border border-white/[0.06] bg-white/[0.02] px-4 py-3 transition-all duration-200 hover:bg-white/[0.03]" data-reveal data-delay={i * 50}>
            <div class="flex items-center gap-2 mb-1">
              <span class={`h-2 w-2 rounded-full ${c.type === "upgrade" ? "bg-emerald-400" : c.type === "add" ? "bg-cyan-400" : "bg-red-400"}`}></span>
              <span class="text-sm font-medium text-white/80">{c.what}</span>
            </div>
            <p class="text-xs text-white/45">{c.from ? `${c.from}` : c.role ? `Rol: ${c.role}` : ""}</p>
            <p class="text-[11px] text-white/30 mt-0.5">por {c.who} — {c.when}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="mt-6 premium-panel p-5 md:p-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center">
      <div class="relative flex-1 max-w-xs">
        <svg class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input class="input-premium w-full pl-10" placeholder="Buscar por usuario, rol o permiso" />
      </div>
    </div>
  </section>
</BusinessLayout>
