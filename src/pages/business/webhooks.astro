---
import BusinessLayout from "../../layouts/BusinessLayout.astro";
export const prerender = false;
---

<BusinessLayout title="Webhooks">
  <section class="rounded-2xl border border-white/[0.06] bg-white/[0.02] p-6 md:p-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div><p class="text-xs uppercase tracking-wider text-cyan-100/70">Webhooks</p><h2 class="mt-3 text-3xl font-semibold tracking-tight text-white md:text-4xl">Webhooks avanzados</h2><p class="mt-3 text-sm text-white/50">Recibe notificaciones en tiempo real de los eventos de AverionAI.</p></div>
      <button id="add-webhook-btn" class="btn-primary shrink-0 px-5 py-3 text-sm">+ Crear webhook</button>
    </div>
  </section>

  <section class="mt-6 premium-panel p-8 text-center">
    <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-xl border border-white/[0.06] bg-white/[0.02]"><svg class="h-7 w-7 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg></div>
    <h3 class="mt-4 text-lg font-medium text-white">Sin webhooks configurados</h3>
    <p class="mt-2 text-sm text-white/45">Crea tu primer webhook para empezar a recibir eventos.</p>
  </section>

  <div id="webhook-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm">
    <div class="mx-4 w-full max-w-md rounded-2xl border border-white/[0.08] bg-[#07070A] p-6 shadow-[0_40px_100px_-40px_rgba(34,211,238,0.3)] md:p-8">
      <div class="flex items-center justify-between mb-6"><h3 class="text-xl font-semibold text-white">Crear webhook</h3><button class="close-modal text-white/30 hover:text-white/60"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button></div>
      <div class="space-y-4">
        <label class="block space-y-1.5"><span class="text-sm text-white/60">URL</span><input class="input-premium w-full" placeholder="https://tuapp.com/webhook" /></label>
        <label class="block space-y-1.5"><span class="text-sm text-white/60">Evento</span><select class="input-premium w-full"><option>lead.created</option><option>lead.updated</option><option>lead.moved</option><option>document.generated</option></select></label>
        <label class="block space-y-1.5"><span class="text-sm text-white/60">Secreto</span><input class="input-premium w-full" placeholder="whsec_..." /></label>
        <button class="w-full rounded-xl bg-white px-6 py-3 text-sm font-semibold text-black transition-all duration-300 hover:-translate-y-0.5">Crear webhook</button>
      </div>
    </div>
  </div>
</BusinessLayout>

<script>
  (() => {
    document.getElementById("add-webhook-btn")?.addEventListener("click", () => document.getElementById("webhook-modal")?.classList.remove("hidden", "flex") || document.getElementById("webhook-modal")?.classList.add("flex"));
    document.querySelectorAll(".close-modal").forEach((b) => b.addEventListener("click", () => b.closest("[id$=-modal]")?.classList.add("hidden")));
  })();
</script>
