---
import BusinessLayout from "../../layouts/BusinessLayout.astro";
export const prerender = false;

const team = [
  { name: "Ana Garcia", email: "ana@empresa.com", role: "Admin", status: "Activo" },
  { name: "Carlos Lopez", email: "carlos@empresa.com", role: "Editor", status: "Activo" },
  { name: "Maria Perez", email: "maria@empresa.com", role: "Viewer", status: "Inactivo" },
];
---

<BusinessLayout title="Equipo">
  <section class="rounded-2xl border border-white/[0.06] bg-white/[0.02] p-6 md:p-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div><p class="text-xs uppercase tracking-wider text-cyan-100/70">Usuarios</p><h2 class="mt-3 text-3xl font-semibold tracking-tight text-white md:text-4xl">Equipo</h2><p class="mt-3 text-sm text-white/50">Gestiona los usuarios de tu plan Business.</p></div>
      <button id="add-user-btn" class="btn-primary shrink-0 px-5 py-3 text-sm text-center">+ Anadir usuario</button>
    </div>
  </section>

  <section class="mt-6 premium-panel overflow-hidden">
    <div class="overflow-x-auto">
      <table class="table-premium">
        <thead><tr><th>Nombre</th><th>Email</th><th>Rol</th><th>Estado</th><th class="text-right">Accion</th></tr></thead>
        <tbody>
          {team.map((u) => (<tr><td class="font-medium text-white">{u.name}</td><td class="text-white/60">{u.email}</td><td><span class="rounded-full border border-white/[0.08] bg-white/[0.03] px-2.5 py-0.5 text-[11px] text-white/50">{u.role}</span></td><td><span class={`rounded-full border px-2.5 py-0.5 text-[11px] font-medium ${u.status === "Activo" ? "border-emerald-300/20 bg-emerald-300/10 text-emerald-200" : "border-white/10 bg-white/[0.04] text-white/40"}`}>{u.status}</span></td><td class="text-right"><div class="flex justify-end gap-2"><button class="text-xs text-cyan-200 hover:text-white transition">Editar</button><button class="text-xs text-amber-300/70 hover:text-amber-200 transition">Suspender</button></div></td></tr>))}
        </tbody>
      </table>
    </div>
  </section>

  <div id="add-user-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm">
    <div class="mx-4 w-full max-w-md rounded-2xl border border-white/[0.08] bg-[#07070A] p-6 shadow-[0_40px_100px_-40px_rgba(34,211,238,0.3)] md:p-8">
      <div class="flex items-center justify-between mb-6"><h3 class="text-xl font-semibold text-white">Anadir usuario</h3><button class="close-modal text-white/30 hover:text-white/60"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button></div>
      <div class="space-y-4">
        <label class="block space-y-1.5"><span class="text-sm text-white/60">Nombre</span><input class="input-premium w-full" placeholder="Nombre completo" /></label>
        <label class="block space-y-1.5"><span class="text-sm text-white/60">Email</span><input class="input-premium w-full" placeholder="email@empresa.com" /></label>
        <label class="block space-y-1.5"><span class="text-sm text-white/60">Rol</span><select class="input-premium w-full"><option>Admin</option><option selected>Editor</option><option>Viewer</option></select></label>
        <button class="w-full rounded-xl bg-white px-6 py-3 text-sm font-semibold text-black transition-all duration-300 hover:-translate-y-0.5">Anadir usuario</button>
      </div>
    </div>
  </div>
</BusinessLayout>

<script>
  (() => {
    document.getElementById("add-user-btn")?.addEventListener("click", () => document.getElementById("add-user-modal")?.classList.remove("hidden", "flex") || document.getElementById("add-user-modal")?.classList.add("flex"));
    document.querySelectorAll(".close-modal").forEach((b) => b.addEventListener("click", () => b.closest("[id$=-modal]")?.classList.add("hidden")));
  })();
</script>
