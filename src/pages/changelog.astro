---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

export const prerender = false;

const entries = [
  { version: "1.0.0", date: "13 mayo 2026", type: "major", emoji: "🚀", label: "Lanzamiento", changes: ["Lanzamiento público de AverionAI", "Landing page premium con animaciones", "CRM completo con leads y pipeline", "Facturación con PDF profesional", "Pitch decks y ebooks con IA", "Integración Stripe para pagos", "Dashboard premium con trial 30min", "Panel admin con analítica global", "Blog SEO con artículos", "Página de referidos", "Healthcheck y monitorización", "SEO extremo con Schema.org completo"] },
  { version: "0.9.0", date: "12 mayo 2026", type: "feature", emoji: "✨", label: "Nueva funcionalidad", changes: ["Sistema de logs y auditoría", "Rate limiting en login", "Protección CSRF mejorada", "Email automation conectado a eventos", "Marketing triggers automáticos", "Badges y logros en dashboard", "Landing pages para campañas"] },
  { version: "0.8.0", date: "11 mayo 2026", type: "feature", emoji: "✨", label: "Nueva funcionalidad", changes: ["Rebrand completo a AverionAI", "Nuevo logo y banner profesional", "PDFs profesionales con branding", "Dropdowns y selects con estilo mejorado", "Sitemap XML y robots.txt", "Schema.org avanzado", "Onboarding para nuevos usuarios"] },
  { version: "0.7.0", date: "10 mayo 2026", type: "feature", emoji: "✨", label: "Nueva funcionalidad", changes: ["CRM v2 con timeline por lead", "Paginación SSR en listas de leads", "Búsqueda con filtros y tags", "Exportación CSV segura", "Mejoras de seguridad en API", "Prisma resiliente con isDbReady"] },
  { version: "0.6.0", date: "9 mayo 2026", type: "feature", emoji: "✨", label: "Nueva funcionalidad", changes: ["Sistema de facturación real", "Pitch decks con IA", "Ebooks con IA", "Informes ejecutivos con PDF", "Portal de Stripe para gestión"] },
  { version: "0.5.0", date: "8 mayo 2026", type: "feature", emoji: "✨", label: "Nueva funcionalidad", changes: ["Registro y login de usuarios", "Trial automático de 30 minutos", "Dashboard de usuario con sidebar", "Middleware con rutas protegidas", "Navbar dinámico según auth"] },
  { version: "0.4.0", date: "7 mayo 2026", type: "feature", emoji: "✨", label: "Nueva funcionalidad", changes: ["Integración Stripe completa", "Webhooks de suscripción", "Página de pricing con checkout", "Estado premium en tiempo real"] },
  { version: "0.3.0", date: "6 mayo 2026", type: "feature", emoji: "✨", label: "Nueva funcionalidad", changes: ["Landing page inicial", "Formulario de leads público", "Email de notificación con Resend", "Admin CRM básico"] },
  { version: "0.2.0", date: "5 mayo 2026", type: "feature", emoji: "✨", label: "Nueva funcionalidad", changes: ["Autenticación con sesiones SSR", "Middleware de seguridad", "Panel admin con login", "Conexión a Supabase/Postgres"] },
  { version: "0.1.0", date: "4 mayo 2026", type: "initial", emoji: "📦", label: "Inicial", changes: ["Proyecto Astro inicial", "Configuración SSR con Vercel", "Prisma con modelo User y Lead", "Estilos Tailwind oscuros"] },
];

const typeStyles: Record<string, string> = {
  major: "border-cyan-300/20 bg-cyan-300/10 text-cyan-200",
  feature: "border-emerald-300/20 bg-emerald-300/10 text-emerald-200",
  initial: "border-white/10 bg-white/[0.04] text-white/50",
};
---

<BaseLayout title="Changelog | AverionAI">
  <Navbar />
  <main class="min-h-screen bg-[#07070A]">
    <section class="container py-20 md:py-28">
      <div class="mx-auto max-w-3xl text-center" data-reveal>
        <span class="badge bg-cyan-300/10 text-cyan-100">Changelog</span>
        <h1 class="mt-5 text-4xl font-semibold text-white md:text-5xl">Historial de versiones</h1>
        <p class="mx-auto mt-4 max-w-xl text-white/60">Todas las actualizaciones y mejoras de AverionAI, desde el primer commit hasta el lanzamiento.</p>
      </div>

      <div class="relative mx-auto mt-20 max-w-3xl">
        <div class="pointer-events-none absolute left-6 top-0 h-full w-px bg-gradient-to-b from-cyan-300/30 to-transparent hidden md:block"></div>

        {entries.map((entry, i) => (
          <div class="relative mb-6 last:mb-0" data-reveal data-delay={i * 80}>
            <div class="md:ml-16 rounded-2xl border border-white/10 bg-white/[0.035] p-6 transition-all duration-300 hover:border-white/15 hover:bg-white/[0.05] hover:-translate-y-0.5">
              <div class="flex flex-wrap items-center gap-3">
                <div class="hidden md:flex absolute left-[-52px] top-7 h-9 w-9 items-center justify-center rounded-xl border border-white/10 bg-[#07070A]">
                  <span class="text-sm">{entry.emoji}</span>
                </div>
                <span class={`rounded-full border px-3 py-1 text-xs font-medium ${typeStyles[entry.type]}`}>v{entry.version}</span>
                <span class="text-xs text-white/40">{entry.date}</span>
                <span class="text-[10px] uppercase tracking-wider text-white/30">{entry.emoji} {entry.label}</span>
              </div>
              <ul class="mt-5 grid gap-2">
                {entry.changes.map((change) => (
                  <li class="flex items-start gap-3 text-sm text-white/70">
                    <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-cyan-400/40"></span>
                    {change}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>

      <div class="mx-auto mt-16 max-w-md text-center" data-reveal>
        <p class="text-sm text-white/50">¿Quieres estar al día de las novedades?</p>
        <a href="/register" class="btn-secondary mt-4 inline-flex px-6 py-2.5 text-sm">Crear cuenta gratis</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
