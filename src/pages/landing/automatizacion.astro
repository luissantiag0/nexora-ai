---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import LeadCaptureModal from "../../components/LeadCaptureModal.astro";

export const prerender = false;
---

<BaseLayout title="Automatización con IA para empresas | AverionAI" description="Transforma tus procesos con automatización inteligente. CRM, RAG, facturación y más en una plataforma SaaS.">
  <Navbar />
  <main class="min-h-screen bg-[#07070A]">
    <section class="relative overflow-hidden border-b border-white/10 pb-20 pt-16 md:pb-28 md:pt-24">
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(34,211,238,0.1),transparent_60%)]"></div>
      <div class="container">
        <div class="mx-auto max-w-3xl text-center" data-reveal>
          <span class="badge bg-cyan-300/10 text-cyan-100">Automatización Inteligente</span>
          <h1 class="mt-6 text-4xl font-semibold tracking-tight text-white md:text-6xl">Automatiza tu empresa con IA</h1>
          <p class="mt-5 text-lg text-white/60">CRM, facturación, documentos y análisis potenciados por inteligencia artificial. Todo en una plataforma SaaS.</p>
          <div class="mt-9 flex flex-wrap justify-center gap-4">
            <a href="/register" class="btn-primary px-8 py-3">Empezar gratis</a>
            <button type="button" data-open-lead-modal class="btn-secondary px-8 py-3">Solicitar demo</button>
          </div>
        </div>
      </div>
    </section>

    <section class="container py-20 md:py-24">
      <div class="grid gap-8 md:grid-cols-3">
        {[
          { title: "CRM Inteligente", desc: "Gestiona leads con clasificación automática por IA. Prioriza oportunidades y automatiza seguimientos." },
          { title: "Documentos con IA", desc: "Genera facturas, informes y pitch decks automáticamente. Exporta a PDF profesional con un clic." },
          { title: "Automatización Total", desc: "Conecta tus herramientas y automatiza flujos de trabajo sin necesidad de código." },
        ].map((item, i) => (
          <div class="card-premium-hover p-6" data-reveal data-delay={i * 100}>
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-cyan-300/10 text-xl icon-float" style="animation-delay:{i * 0.3}s">0{i + 1}</div>
            <h3 class="mt-5 text-lg font-semibold text-white">{item.title}</h3>
            <p class="mt-3 text-sm text-white/60">{item.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="border-t border-white/10 bg-white/[0.02] py-20">
      <div class="container text-center">
        <h2 class="text-3xl font-semibold text-white md:text-4xl">Prueba AverionAI gratis</h2>
        <p class="mt-4 text-white/60">30 minutos de acceso premium sin tarjeta de crédito.</p>
        <a href="/register" class="btn-primary mt-8 px-8 py-3 inline-flex">Empezar ahora</a>
      </div>
    </section>
  </main>
  <Footer />
  <LeadCaptureModal />
</BaseLayout>
