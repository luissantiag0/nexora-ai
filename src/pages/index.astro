---
console.log("[ssr] Rendering homepage /");

import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Services from "../components/Services.astro";
import Features from "../components/Features.astro";
import UseCases from "../components/UseCases.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
import LeadCaptureModal from "../components/LeadCaptureModal.astro";

console.log("[ssr] Homepage imports OK");
---

<BaseLayout
  title="AverionAI | Sistemas de automatización con IA para empresas modernas"
  description="AverionAI desarrolla sistemas de automatización con IA, plataformas RAG, aplicaciones de facturación con IA, generación de ebooks y soluciones SaaS personalizadas."
>
  <Navbar />
  <main>
    <Hero />
    <Services />
    <Features />
    <UseCases />

    <section class="border-t border-white/[0.06] py-24 md:py-28">
      <div class="container">
        <div class="mx-auto max-w-3xl text-center" data-reveal>
          <span class="inline-flex items-center rounded-full border border-cyan-300/20 bg-cyan-300/[0.06] px-3 py-1 text-xs font-medium tracking-wider text-cyan-200/80 uppercase">Por que elegirnos</span>
          <h2 class="mt-5 text-3xl font-semibold tracking-tight text-white md:text-5xl">IA que transforma, no solo tecnologia</h2>
          <p class="mt-4 text-base text-white/50">No todos los sistemas de IA son iguales. Comparamos para que decidas con claridad.</p>
        </div>

        <div class="mx-auto mt-16 grid max-w-5xl gap-6 md:grid-cols-2">
          <div class="rounded-2xl border border-cyan-300/20 bg-[linear-gradient(135deg,rgba(34,211,238,0.08),rgba(255,255,255,0.03)_48%,rgba(16,185,129,0.06))] p-6 md:p-8" data-reveal data-delay="0">
            <div class="flex items-center gap-3 mb-6">
              <span class="flex h-8 w-8 items-center justify-center rounded-full bg-cyan-300/20 text-sm font-bold text-cyan-200">A</span>
              <span class="text-lg font-semibold text-white">AverionAI</span>
            </div>
            <p class="text-sm text-white/50 mb-6">Sistemas inteligentes que hacen crecer tu negocio</p>
            <ul class="grid gap-4">
              {["Automatizaciones que generan clientes", "IA aplicada con enfoque empresarial", "Procesos que escalan", "Decisiones basadas en datos", "Optimizacion operativa real", "Implementacion rapida"].map((item) => (
                <li class="flex items-start gap-3 text-sm text-white/80">
                  <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-emerald-400/20 text-emerald-300 text-xs font-bold">✓</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] p-6 md:p-8 opacity-60" data-reveal data-delay="100">
            <div class="flex items-center gap-3 mb-6">
              <span class="flex h-8 w-8 items-center justify-center rounded-full bg-white/10 text-sm font-bold text-white/40">T</span>
              <span class="text-lg font-semibold text-white/40">Agencias tradicionales</span>
            </div>
            <p class="text-sm text-white/30 mb-6">Lo de siempre, sin impacto real</p>
            <ul class="grid gap-4">
              {["Acciones sueltas sin estrategia", "IA superficial sin resultados", "Procesos manuales que no escalan", "Decisiones sin datos", "Implementacion lenta", "Informes sin retorno"].map((item) => (
                <li class="flex items-start gap-3 text-sm text-white/40">
                  <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-white/10 text-white/30 text-xs">✕</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <FAQ />
    <CTA />
  </main>
  <Footer />
  <LeadCaptureModal />
</BaseLayout>
