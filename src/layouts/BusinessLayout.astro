---
import "../styles/global.css";
import BrandLogo from "../components/BrandLogo.astro";

const { title = "Business" } = Astro.props;
const user = Astro.locals.user;

const navItems = [
  { label: "Dashboard", href: "/business/dashboard" },
  { label: "Equipo", href: "/business/users" },
  { label: "Roles", href: "/business/roles" },
  { label: "API", href: "/business/api" },
  { label: "Integrations", href: "/business/integrations" },
  { label: "Webhooks", href: "/business/webhooks" },
  { label: "Actividad", href: "/business/activity" },
  { label: "Soporte", href: "/business/support" },
];

const isActive = (href: string) => Astro.url.pathname === href;
---

<!doctype html>
<html lang="es">
  <head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>{title} | AverionAI Business</title><meta name="theme-color" content="#07070A" /></head>
  <body class="min-h-screen bg-[#07070A] text-white antialiased selection:bg-cyan-300/20 selection:text-cyan-100">
    <div class="min-h-screen lg:flex">
      <aside class="hidden border-r border-white/10 bg-[#07070A]/92 px-5 py-6 backdrop-blur-xl lg:fixed lg:inset-y-0 lg:flex lg:w-64 lg:flex-col">
        <BrandLogo markClass="h-9 w-9" textClass="text-base" />
        <nav class="mt-10 grid gap-1.5 text-sm" aria-label="Business">
          {navItems.map((item) => (
            <a href={item.href} class={`rounded-lg border px-4 py-2.5 transition duration-300 ${isActive(item.href) ? "border-cyan-300/30 bg-cyan-300/10 text-cyan-100" : "border-transparent text-white/55 hover:border-white/10 hover:bg-white/[0.04] hover:text-white"}`}>{item.label}</a>
          ))}
        </nav>
        <div class="mt-auto rounded-xl border border-white/10 bg-white/[0.035] p-3.5">
          <p class="text-xs text-cyan-100/60">Business plan</p>
          <p class="mt-1 text-xs text-white/40">Equipos y empresas</p>
        </div>
      </aside>
      <div class="flex min-h-screen w-full flex-col lg:pl-64">
        <header class="sticky top-0 z-40 border-b border-white/10 bg-[#07070A]/82 backdrop-blur-xl">
          <div class="flex min-h-14 items-center justify-between px-5 md:px-8">
            <div class="flex items-center gap-3">
              <div class="lg:hidden"><BrandLogo markClass="h-8 w-8" textClass="text-base" /></div>
              <a href="/business/dashboard" class="hidden text-xs text-white/30 hover:text-cyan-200 transition items-center gap-1.5 lg:flex">
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                Business Dashboard
              </a>
              <span class="hidden text-white/10 lg:block">/</span>
              <p class="text-sm text-white/40">{title}</p>
            </div>
            <div class="flex items-center gap-3">
              <a href="/dashboard" class="text-xs text-white/40 hover:text-cyan-200 transition">Dashboard</a>
              <form method="POST" action="/logout"><button class="btn-secondary px-3 py-1.5 text-xs">Salir</button></form>
            </div>
          </div>
          <nav class="flex gap-1 overflow-x-auto border-t border-white/10 px-5 py-2 text-sm md:px-8 lg:hidden">
            {navItems.map((item) => (
              <a href={item.href} class={`shrink-0 rounded-lg border px-3 py-1.5 text-xs transition ${isActive(item.href) ? "border-cyan-300/30 bg-cyan-300/10 text-cyan-100" : "border-white/10 bg-white/[0.02] text-white/55"}`}>{item.label}</a>
            ))}
          </nav>
        </header>
        <main class="flex-1 px-5 py-6 md:px-8 md:py-8"><slot /></main>
      </div>
    </div>
  </body>
</html>
